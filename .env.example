# =============================================================================
# VisionFlow Studio — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in values as needed for your environment.
#   cp .env.example .env
# All values here are defaults for local development.
# =============================================================================

# =============================================================================
# --- Application ---
# =============================================================================

# Node environment. Use "development" for local dev with verbose logging,
# "production" for production deployments.
NODE_ENV=development

# Logging verbosity. Options: trace, debug, info, warn, error, fatal.
# Development default is "debug"; production should use "warn" or "error".
LOG_LEVEL=debug

# When "true", the API uses in-memory stores instead of PostgreSQL/Redis/MinIO.
# Useful for demos or running tests without Docker infrastructure.
# Default: false
DEMO_MODE=false

# Explicit data mode. Options: "database" (use Postgres), "memory" (use in-memory stores).
# Overrides DEMO_MODE when set. Default: database
DATA_MODE=database

# =============================================================================
# --- CORS ---
# =============================================================================

# Allowed origin(s) for CORS requests from the web frontend.
# Must match the URL the browser uses to access the web app exactly.
# Vite auto-assigns 5173 → 5174 → 5175 if lower ports are taken.
# Default: http://localhost:5173
WEB_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# =============================================================================
# --- Security ---
# =============================================================================

# Time in seconds for MinIO signed URLs to remain valid. Set to 0 to disable
# signed URLs and use API proxy mode instead (assets are streamed through API).
# Default: 3600 (presigned URL mode; use 0 for local-private proxy mode)
SIGNED_URL_EXPIRY_SECONDS=3600

# =============================================================================
# --- Database ---
# =============================================================================

# PostgreSQL connection string. The database must exist on the target host.
# Change host/port/credentials if using Docker or a remote PostgreSQL instance.
DATABASE_URL=postgresql://visionflow:visionflow@localhost:5432/visionflow?schema=public

# =============================================================================
# --- Redis ---
# =============================================================================

# Redis host for BullMQ job queue.
REDIS_HOST=localhost

# Redis port. Default: 6380 (use 6379 only if no local redis-server is running).
REDIS_PORT=6380

# Redis password. Leave empty for local development (no auth).
REDIS_PASSWORD=

# Queue library mode. Only "bullmq" is currently supported.
INFERENCE_QUEUE_MODE=bullmq

# BullMQ queue name for inference jobs.
INFERENCE_QUEUE_NAME=inference-jobs

# Queue library mode. Options: "bullmq" (use BullMQ), "memory" (no worker, jobs stay QUEUED).
# Default: bullmq
MEDIA_QUEUE_MODE=bullmq

# Media worker concurrency (number of media jobs processed in parallel).
# Default: 2
MEDIA_WORKER_CONCURRENCY=2

# Number of inference jobs that can run concurrently per worker instance.
# Increase on machines with more CPU/GPU resources.
# Default: 2
INFERENCE_JOB_CONCURRENCY=2

# Time (ms) between worker progress steps during mock inference.
# Higher values make the SSE progress stream more visible in the UI.
# Default: 180
INFERENCE_WORKER_STEP_MS=180

# =============================================================================
# --- MinIO Storage ---
# =============================================================================

# MinIO endpoint host.
MINIO_ENDPOINT=localhost

# MinIO API port (the S3-compatible port, not the console port).
MINIO_PORT=9000

# Whether to connect to MinIO over HTTPS. Set "true" when MinIO is behind
# a TLS-terminating proxy (e.g., in production).
# Default: false
MINIO_USE_SSL=false

# MinIO access key (username). Must match the MINIO_ROOT_USER in docker-compose.yml.
MINIO_ACCESS_KEY=visionflow

# MinIO secret key (password). Must match the MINIO_ROOT_PASSWORD in docker-compose.yml.
MINIO_SECRET_KEY=visionflow-secret

# MinIO bucket name for storing media originals, thumbnails, and predictions.
# The bucket is created automatically on startup if it does not exist.
MINIO_BUCKET=visionflow-artifacts

# Media storage mode. Options: "minio" (use MinIO/S3), "memory" (use in-memory store).
# Default: minio
MEDIA_STORAGE_MODE=minio

# Maximum allowed upload size in bytes. Default: 262144000 (250 MB)
MAX_UPLOAD_BYTES=262144000

# =============================================================================
# --- API Server ---
# =============================================================================

# Port on which the NestJS API server listens.
API_PORT=3000

# Base URL for CLI scripts/harnesses that call the API (e.g. phase22b API harness).
# Unlike VITE_API_BASE_URL (host-only), this MUST include the /api prefix because
# the NestJS API uses a global /api prefix and scripts append full paths.
# Default: http://localhost:3000/api
API_BASE_URL=http://localhost:3000/api

# =============================================================================
# --- CV Worker ---
# =============================================================================

# Base URL of the FastAPI CV Worker service.
# Must be set for real media processing (thumbnail generation, frame extraction).
# The worker is started by `pnpm dev:cv` or `pnpm dev:full`.
# Default: http://localhost:8000
CV_WORKER_URL=http://localhost:8000

# Comma-separated list of allowed hostnames for CV_WORKER_URL (SSRF protection).
# For containerized setups, add the internal service hostname (e.g., cv-worker).
# Default: localhost,127.0.0.1
CV_WORKER_ALLOWED_HOSTS=localhost,127.0.0.1

# Detector backend mode. Options:
#   "mock"  — deterministic fake detections, no ONNX runtime required.
#   "onnx"   — real ONNX inference using YOLOv8n (requires model weights).
# Default: mock
CV_WORKER_DETECTOR_MODE=mock

# Local filesystem path to the YOLOv8n ONNX model weights.
# Required only when CV_WORKER_DETECTOR_MODE=onnx.
# Download with: pnpm download-model  (or scripts/download-model.ps1 on Windows)
# Default: ./models/yolov8n.onnx
CV_WORKER_ONNX_MODEL_PATH=./models/yolov8n.onnx

# Human-readable model version string embedded in prediction metadata.
# Default: yolov8n-640
CV_WORKER_ONNX_MODEL_VERSION=yolov8n-640

# Confidence threshold — predictions below this score are discarded.
# Default: 0.25
CV_WORKER_CONFIDENCE_THRESHOLD=0.25

# Non-Maximum Suppression (NMS) IoU threshold — overlapping boxes with
# IoU >= this value are suppressed.
# Default: 0.45
CV_WORKER_NMS_IOU_THRESHOLD=0.45

# Input image size (square). The model resizes images to this size using
# letterbox padding before inference.
# Default: 640
CV_WORKER_INPUT_SIZE=640

# HTTP request timeout (ms) when the API calls the CV Worker.
# Increase if running on slow hardware or processing large images.
# Default: 3500
CV_WORKER_TIMEOUT_MS=3500

# =============================================================================
# --- Web App ---
# =============================================================================

# Base URL of the API server, used by the web frontend for HTTP requests.
# The web frontend appends API paths that include /api/ (e.g. /api/health),
# so this MUST be the host+port only — no /api suffix.
# Change this when deploying the API behind a reverse proxy or subdomain.
# Default: http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000

# Base URL of the web frontend, used by Playwright tests for navigation.
# Playwright baseURL must point to the web server, NOT the API.
# Default: http://localhost:5173
VITE_WEB_BASE_URL=http://localhost:5173
