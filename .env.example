# =============================================================
# QUANLYVKS - biến môi trường mẫu (đã có giá trị mặc định an toàn)
# Copy thành `.env` (cùng cấp) và sửa lại cho phù hợp đơn vị thật.
# KHÔNG commit `.env` thật (đã nằm trong .gitignore).
# =============================================================

# ----- Database (MariaDB 11) -----
# Driver Prisma: @prisma/adapter-mariadb + mariadb
# Lưu ý: provider trong schema.prisma vẫn là "mysql" (Prisma 6 + MariaDB).
DATABASE_URL="mysql://quanlyvks:change-me@127.0.0.1:3307/quanlyvks?connection_limit=10"

# ----- MariaDB container (chỉ dùng cho pnpm db:up) -----
MARIADB_IMAGE=mariadb:11
MARIADB_CONTAINER=quanlyvks-mariadb
MARIADB_HOST=127.0.0.1
MARIADB_HOST_PORT=3307
MARIADB_PORT=3306
MARIADB_USER=quanlyvks
MARIADB_PASSWORD=change-me
MARIADB_DATABASE=quanlyvks
MARIADB_ROOT_PASSWORD=root-change-me

# ----- API -----
NODE_ENV=development
TZ=Asia/Ho_Chi_Minh
API_PORT=3001
API_GLOBAL_PREFIX=api/v1
API_CORS_ORIGIN=http://localhost:3000

# ----- Web -----
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
# BACKEND_ORIGIN=http://localhost:3001  # nếu muốn dùng Next.js rewrite /api/* -> backend

# ----- Auth (session cookie) -----
AUTH_SESSION_COOKIE_NAME=qlv_session
AUTH_SESSION_TTL_DAYS=14
AUTH_COOKIE_SECURE=false  # đặt true khi chạy HTTPS

# ----- Storage -----
# Đường dẫn tới folder storage (chứa templates/docx, generated, ...)
# Mặc định: <repo-root>/storage
STORAGE_ROOT=./storage

# ----- Seed -----
# Tên admin mặc định seed cho officials (nếu DB rỗng)
SEED_ADMIN_FULL_NAME=Admin
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_POSITION=Quan tri he thong

# Agency mặc định cho seed
SEED_AGENCY_NAME=Viện kiểm sát
SEED_PARENT_AGENCY_NAME=
SEED_AGENCY_CODE=VKS-DEFAULT
