    {
      "blockId": "P0076",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0077",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh, thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0078",
      "kind": "paragraph",
      "text": "Mẫu này dùng trong trường hợp Viện kiểm sát yêu cầu cơ quan, người có thẩm quyền điều tra ra Lệnh bắt bị can để tạm giam nhưng không thực hiện hoặc trường hợp Viện kiểm sát ra Lệnh bắt bị can để tạm giam trong giai đoạn truy tố",
      "style": null
    },
    {
      "blockId": "P0079",
      "kind": "paragraph",
      "text": "Trường hợp ra Lệnh bắt bị can để tạm giam trong giai đoạn truy tố thì bổ sung căn cứ Điều 236 và Điều 241 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0080",
      "kind": "paragraph",
      "text": "Chỉ ghi căn cứ này trong trường hợp người bị tạm giam là người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0081",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0082",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố bị can",
      "style": null
    },
    {
      "blockId": "P0083",
      "kind": "paragraph",
      "text": "Ghi họ tên bị can",
      "style": null
    },
    {
      "blockId": "P0084",
      "kind": "paragraph",
      "text": "11 Trường hợp trong giai đoạn truy tố thì ghi rõ số ngày tạm giam",
      "style": null
    },
