    {
      "blockId": "P0071",
      "kind": "paragraph",
      "text": "13 Ghi tên cơ quan, người có trách nhiệm thực hiện Lệnh bắt bị can để tạm giam",
      "style": null
    },
    {
      "blockId": "P0072",
      "kind": "paragraph",
      "text": "14 Ghi tên cơ sở giam giữ",
