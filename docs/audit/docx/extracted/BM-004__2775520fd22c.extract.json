  "textBlocks": [
    {
      "blockId": "P0001",
      "kind": "paragraph",
      "text": "Mẫu số 04/HS",
      "style": null
    },
    {
      "blockId": "P0002",
      "kind": "paragraph",
      "text": "(Ban hành theo Thông tư số      /2026/TT-VKSTC",
      "style": null
    },
    {
      "blockId": "P0003",
      "kind": "paragraph",
      "text": "ngày…/…/2026)",
      "style": null
    },
    {
      "blockId": "P0007",
      "kind": "paragraph",
      "text": "VIỆN KIỂM SÁT … .................................................",
      "style": "Heading5"
    },
    {
      "blockId": "P0008",
      "kind": "paragraph",
      "text": "CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM",
      "style": "Heading5"
    },
    {
      "blockId": "P0009",
      "kind": "paragraph",
      "text": "Độc lập – Tự do - Hạnh phúc",
      "style": "Heading5"
    },
    {
      "blockId": "P0011",
      "kind": "paragraph",
      "text": "Số: …/QĐ-VKS…-…",
      "style": null
    },
    {
      "blockId": "P0012",
      "kind": "paragraph",
      "text": "…, ngày … tháng … năm 20…",
      "style": null
    },
    {
      "blockId": "P0015",
      "kind": "paragraph",
      "text": "QUYẾT ĐỊNH",
      "style": null
    },
    {
      "blockId": "P0016",
      "kind": "paragraph",
      "text": "Thay đổi ... thực hành quyền công tố, kiểm sát",
      "style": null
    },
    {
      "blockId": "P0017",
      "kind": "paragraph",
      "text": "việc tiếp nhận, giải quyết nguồn tin về tội phạm",
      "style": null
    },
    {
      "blockId": "P0018",
      "kind": "paragraph",
      "text": "VIỆN TRƯỞNG VIỆN KIỂM SÁT2...",
      "style": null
    },
    {
      "blockId": "P0020",
      "kind": "paragraph",
      "text": "Căn cứ các điều 41, 42, 43, 159 và 160 của Bộ luật Tố tụng hình sự;",
      "style": null
    },
    {
      "blockId": "P0021",
      "kind": "paragraph",
      "text": "Căn cứ Quyết định phân công thực hành quyền công tố, kiểm sát việc tiếp nhận, giải quyết nguồn tin về tội phạm6 số … ngày … tháng … năm … của Viện kiểm sát…;",
      "style": null
    },
    {
      "blockId": "P0022",
      "kind": "paragraph",
      "text": "Xét thấy:………………………………………….………………………………,",
      "style": null
    },
    {
      "blockId": "P0024",
      "kind": "paragraph",
      "text": "QUYẾT ĐỊNH:",
      "style": null
    },
    {
      "blockId": "P0026",
      "kind": "paragraph",
      "text": "Điều 1. Phân công ông/bà...; chức danh… của Viện kiểm sát7… thay cho ông/bà...; chức danh5… của Viện kiểm sát7…, thực hiện nhiệm vụ thực hành quyền công tố, kiểm sát việc tiếp nhận, giải quyết nguồn tin về tội phạm6 của... đối với vụ việc……………………………………………………………………………………....",
      "style": null
    },
    {
      "blockId": "P0027",
      "kind": "paragraph",
      "text": "Điều 2. Các ông/bà có tên nêu tại Điều 1 Quyết định này thực hiện nhiệm vụ, quyền hạn và trách nhiệm theo quy định của Bộ luật Tố tụng hình sự./.",
      "style": null
    },
    {
      "blockId": "P0029",
      "kind": "paragraph",
      "text": "Nơi nhận:",
      "style": null
    },
    {
      "blockId": "P0030",
      "kind": "paragraph",
      "text": "- 12…;",
      "style": null
    },
    {
      "blockId": "P0031",
      "kind": "paragraph",
      "text": "- Như Điều 2;",
      "style": null
    },
    {
      "blockId": "P0032",
      "kind": "paragraph",
      "text": "- Lưu: HSVA, HSKS, VP.",
      "style": null
    },
    {
      "blockId": "P0034",
      "kind": "paragraph",
      "text": "..………………………….…",
      "style": null
    },
    {
      "blockId": "P0035",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    }
  ],
