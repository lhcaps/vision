      "style": null
    },
    {
      "blockId": "P0058",
      "kind": "paragraph",
      "text": "ĐẠI DIỆN UỶ BAN NHÂN DÂN CẤP XÃ                                                  (Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0059",
      "kind": "paragraph",
      "text": "BỊ CAN/NGƯỜI ĐẠI DIỆN CỦA BỊ CAN",
      "style": null
    },
    {
      "blockId": "P0060",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên)",
      "style": null
    },
    {
      "blockId": "P0061",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0062",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0063",
      "kind": "paragraph",
      "text": "Ghi họ tên bị can; trường hợp kê biên tài sản của pháp nhân thì ghi đầy đủ thông tin về pháp nhân (gồm: tên pháp nhân, địa chỉ đặt trụ sở chính, số đăng ký kinh doanh, quốc tịch, họ tên người đại diện theo pháp luật,",
      "style": null
    },
    {
      "blockId": "P0064",
      "kind": "paragraph",
      "text": "Ghi rõ tên gọi, số lượng, tình trạng từng tài sản bị kê biên",
      "style": null
    },
    {
      "blockId": "P0065",
      "kind": "paragraph",
      "text": "Ghi rõ: chủ tài sản, người quản lý hợp pháp hoặc người thân thích của người bị kê biên tài sản",
