    {
      "blockId": "P0019",
      "kind": "paragraph",
      "text": "1. Cơ quan, người có thẩm quyền",
      "style": null
    },
    {
      "blockId": "P0020",
      "kind": "paragraph",
      "text": "chuyển nguồn tin về tội phạm nêu trên và tài liệu, đồ vật kèm theo đến cơ quan, người có thẩm quyền",
      "style": null
