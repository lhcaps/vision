    {
      "blockId": "P0023",
      "kind": "paragraph",
      "text": "....",
      "style": null
    },
    {
      "blockId": "P0024",
      "kind": "paragraph",
      "text": "1.3. Đánh giá nguyên nhân vi phạm, trách nhiệm để xảy ra vi phạm",
