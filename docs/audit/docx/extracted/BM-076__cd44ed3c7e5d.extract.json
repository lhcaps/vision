    {
      "blockId": "P0012",
      "kind": "paragraph",
      "text": "Thay đổi người phiên dịch/người dịch thuật",
      "style": null
    },
    {
      "blockId": "P0013",
      "kind": "paragraph",
      "text": "VIỆN TRƯỞNG VIỆN KIỂM SÁT2...",
      "style": null
    },
    {
      "blockId": "P0014",
      "kind": "paragraph",
      "text": "Căn cứ Điều 41, khoản 4 và khoản 5 Điều 70 của Bộ luật Tố tụng hình sự;",
      "style": null
    },
    {
      "blockId": "P0015",
      "kind": "paragraph",
      "text": "Xét thấy",
      "style": null
    },
    {
      "blockId": "P0016",
      "kind": "paragraph",
      "text": ".................,",
      "style": null
    },
    {
      "blockId": "P0017",
      "kind": "paragraph",
      "text": "QUYẾT ĐỊNH:",
      "style": null
    },
    {
      "blockId": "P0018",
      "kind": "paragraph",
      "text": "Điều 1. Thay đổi người phiên dịch/người dịch thuật là ông/bà",
      "style": null
    },
    {
      "blockId": "P0019",
      "kind": "paragraph",
      "text": "đang được cử làm phiên dịch cho",
      "style": null
    },
    {
      "blockId": "P0020",
      "kind": "paragraph",
      "text": "/dịch thuật tài liệu",
      "style": null
    },
    {
      "blockId": "P0021",
      "kind": "paragraph",
      "text": "... trong vụ việc/vụ án",
      "style": null
    },
    {
      "blockId": "P0022",
      "kind": "paragraph",
      "text": "Điều 2. Đề nghị",
      "style": null
    },
    {
      "blockId": "P0023",
      "kind": "paragraph",
      "text": "cử người khác có khả năng phiên dịch/dịch thuật thay cho ông/bà6",
      "style": null
    },
    {
      "blockId": "P0024",
      "kind": "paragraph",
      "text": "theo quy định tại khoản 1 Điều 70 của Bộ luật Tố tụng hình sự.",
      "style": null
    },
    {
      "blockId": "P0025",
      "kind": "paragraph",
      "text": "Điều 3. Người phiên dịch/người dịch thuật được thay thế có quyền và nghĩa vụ theo quy định tại Điều 70 của Bộ luật Tố tụng hình sự./.",
      "style": null
    },
    {
      "blockId": "P0026",
      "kind": "paragraph",
      "text": "Nơi nhận:",
      "style": null
    },
    {
      "blockId": "P0027",
      "kind": "paragraph",
      "text": "- 10...;",
      "style": null
    },
    {
      "blockId": "P0028",
      "kind": "paragraph",
      "text": "- Lưu: HSVV/HSVA, HSKS, VP.",
      "style": null
    },
    {
      "blockId": "P0029",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0030",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0031",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0032",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0033",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh, thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0034",
      "kind": "paragraph",
      "text": "Ghi lý do cần thay đổi người phiên dịch/người dịch thuật theo quy định tại khoản 4 Điều 70 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0035",
      "kind": "paragraph",
      "text": "Ghi họ tên người đang được cử làm phiên dịch/dịch thuật",
      "style": null
    },
    {
      "blockId": "P0036",
      "kind": "paragraph",
      "text": "Ghi họ tên người tham gia tố tụng được phiên dịch",
      "style": null
    },
    {
      "blockId": "P0037",
      "kind": "paragraph",
      "text": "Ghi tên tài liệu cần dịch thuật",
      "style": null
    },
    {
      "blockId": "P0038",
      "kind": "paragraph",
      "text": "Trích dẫn ngắn gọn nội dung vụ việc (nguồn cung cấp, thời gian, địa điểm, hành vi có dấu hiệu tội phạm,",
      "style": null
    },
    {
      "blockId": "P0039",
      "kind": "paragraph",
      "text": "). Trường hợp vụ án thì ghi rõ theo Quyết định khởi tố vụ án số",
      "style": null
    },
    {
      "blockId": "P0040",
