    {
      "blockId": "P0044",
      "kind": "paragraph",
      "text": "Nhận thấy việc định giá tài sản là cần thiết,",
      "style": null
    },
    {
      "blockId": "P0045",
      "kind": "paragraph",
      "text": "YÊU CẦU:",
      "style": null
    },
    {
      "blockId": "P0046",
      "kind": "paragraph",
      "text": "1. Hội đồng định giá",
      "style": null
    },
    {
      "blockId": "P0047",
      "kind": "paragraph",
      "text": "tiến hành định giá tài sản sau:",
      "style": null
    },
    {
      "blockId": "P0048",
      "kind": "paragraph",
      "text": "1.1. Thông tin và đặc điểm của tài sản cần định giá, nơi bảo quản các tài sản này:...",
      "style": null
    },
    {
      "blockId": "P0049",
      "kind": "paragraph",
      "text": "1.2. Tên tài liệu có liên quan (nếu có):",
      "style": null
    },
    {
      "blockId": "P0050",
      "kind": "paragraph",
      "text": "1.3. Nội dung yêu cầu định giá tài sản:",
      "style": null
    },
    {
      "blockId": "P0051",
      "kind": "paragraph",
      "text": "1.4. Thời hạn định giá tài sản từ ngày",
      "style": null
    },
    {
      "blockId": "P0052",
      "kind": "paragraph",
      "text": "tháng",
      "style": null
    },
    {
      "blockId": "P0053",
      "kind": "paragraph",
      "text": "năm",
      "style": null
    },
    {
      "blockId": "P0054",
      "kind": "paragraph",
      "text": "đến ngày",
      "style": null
    },
    {
      "blockId": "P0055",
      "kind": "paragraph",
      "text": "tháng",
      "style": null
    },
    {
      "blockId": "P0056",
      "kind": "paragraph",
      "text": "năm",
      "style": null
    },
    {
      "blockId": "P0057",
      "kind": "paragraph",
      "text": "Hội đồng định giá tài sản phải gửi Kết luận định giá tài sản cho Viện kiểm sát2",
      "style": null
    },
    {
      "blockId": "P0058",
      "kind": "paragraph",
      "text": "Người định giá tài sản có quyền và nghĩa vụ theo Điều 69 của Bộ luật Tố tụng hình sự.",
      "style": null
    },
    {
      "blockId": "P0059",
      "kind": "paragraph",
      "text": "Kèm theo yêu cầu này là hồ sơ, tài liệu có liên quan./.",
      "style": null
    },
    {
      "blockId": "P0060",
      "kind": "paragraph",
      "text": "Nơi nhận:",
      "style": null
    },
    {
      "blockId": "P0061",
      "kind": "paragraph",
      "text": "- 11...;",
      "style": null
    },
    {
      "blockId": "P0062",
      "kind": "paragraph",
      "text": "- Lưu: HSVV/VA, HSKS, VP.",
      "style": null
    },
    {
      "blockId": "P0063",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0064",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0065",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0066",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0067",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0068",
      "kind": "paragraph",
      "text": "Trường hợp Quyết định yêu cầu định giá tài sản trong giai đoạn truy tố thì ghi căn cứ Điều 236 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0069",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0070",
      "kind": "paragraph",
      "text": "Trường hợp trưng cầu giám định theo quy định tại điểm d khoản 3 Điều 147 của Bộ luật Tố tụng hình sự thì không cần căn cứ này",
      "style": null
    },
    {
      "blockId": "P0071",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố bị can",
      "style": null
    },
    {
      "blockId": "P0072",
      "kind": "paragraph",
      "text": "Ghi họ tên người hoặc tên pháp nhân bị khởi tố",
      "style": null
    },
    {
      "blockId": "P0073",
      "kind": "paragraph",
      "text": "Ghi họ tên, tư cách tham gia tố tụng của người đề nghị",
      "style": null
    },
    {
      "blockId": "P0074",
      "kind": "paragraph",
      "text": "Ghi tên Hội đồng định giá được yêu cầu định giá tài sản",
      "style": null
    },
    {
      "blockId": "P0075",
      "kind": "paragraph",
      "text": "Ghi chức danh người ký",
      "style": null
    },
