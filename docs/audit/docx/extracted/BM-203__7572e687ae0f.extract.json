    {
      "blockId": "P0046",
      "kind": "paragraph",
      "text": "KIỂM SÁT VIÊN",
      "style": null
    },
    {
      "blockId": "P0047",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
