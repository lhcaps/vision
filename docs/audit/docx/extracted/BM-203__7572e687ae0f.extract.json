      "style": null
    },
    {
      "blockId": "P0051",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0052",
      "kind": "paragraph",
      "text": "Mẫu này dùng trong trường hợp thông báo cho người bào chữa/người đại diện/người bảo về quyền và lợi ích hợp pháp của người chưa thành niên là người bị tố giác, người bị kiến nghị khởi tố, người bị giữ trong trường hợp khẩn cấp, người bị buộc tội biết về thời gian, địa điểm tiến hành hoạt động tố tụng mà họ có quyền tham gia",
      "style": null
    },
    {
      "blockId": "P0053",
      "kind": "paragraph",
      "text": "Ghi họ tên người được thông báo",
      "style": null
    },
    {
      "blockId": "P0054",
      "kind": "paragraph",
      "text": "Ghi rõ người đại diện/người bào chữa/người bảo về quyền và lợi ích hợp pháp",
      "style": null
    },
    {
      "blockId": "P0055",
      "kind": "paragraph",
      "text": "Ghi họ tên người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0056",
      "kind": "paragraph",
      "text": "Ghi rõ tư cách tham gia tố tụng",
      "style": null
    },
    {
      "blockId": "P0057",
      "kind": "paragraph",
      "text": "Ghi tóm tắt nội dung vụ việc; trường hợp vụ án thì ghi rõ khởi tố theo Quyết định khởi tố vụ án hình sự số",
      "style": null
    },
