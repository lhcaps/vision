    {
      "blockId": "P0053",
      "kind": "paragraph",
      "text": "KIỂM SÁT VIÊN",
      "style": null
    },
    {
      "blockId": "P0054",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0055",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0056",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0057",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0058",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0059",
      "kind": "paragraph",
      "text": "Ghi rõ Người làm chứng, người bị tố giác, người bị kiến nghị khởi tố, người bị hại hoặc người đại diện theo pháp luật của pháp nhân",
      "style": null
    },
    {
      "blockId": "P0060",
      "kind": "paragraph",
      "text": "Hoặc Điều 57 hoặc Điều 62 hoặc Điều 440 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0061",
      "kind": "paragraph",
      "text": "Chỉ ghi căn cứ này trong trường hợp người bị dẫn giải là người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0062",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0063",
      "kind": "paragraph",
      "text": "Ghi họ tên người cần dẫn giải",
      "style": null
    },
    {
      "blockId": "P0064",
      "kind": "paragraph",
      "text": "Trích dẫn ngắn gọn nội dung vụ việc (nguồn cung cấp, thời gian, địa điểm, hành vi có dấu hiệu tội phạm,",
      "style": null
    },
    {
      "blockId": "P0065",
      "kind": "paragraph",
      "text": "). Trường hợp vụ án thì ghi rõ theo Quyết định khởi tố vụ án số",
      "style": null
    },
    {
      "blockId": "P0066",
