  "textBlocks": [
    {
      "blockId": "P0001",
      "kind": "paragraph",
      "text": "Mẫu số 01/HS",
      "style": null
    },
    {
      "blockId": "P0002",
      "kind": "paragraph",
      "text": "(Ban hành theo Thông tư  số 03/2026/TT-VKSTC",
      "style": null
    },
    {
      "blockId": "P0003",
      "kind": "paragraph",
      "text": "Ngày 09/02/2026)",
      "style": null
    },
    {
      "blockId": "P0004",
      "kind": "paragraph",
      "text": "VIỆN KIỂM SÁT NHÂN DÂN",
      "style": null
    },
    {
      "blockId": "P0005",
      "kind": "paragraph",
      "text": "THÀNH PHỐ HỒ CHÍ MINH",
      "style": null
    },
    {
      "blockId": "P0006",
      "kind": "paragraph",
      "text": "VIỆN KIỂM SÁT NHÂN DÂN KHU VỰC 7",
      "style": null
    },
    {
      "blockId": "P0007",
      "kind": "paragraph",
      "text": "──────",
      "style": null
    },
    {
      "blockId": "P0008",
      "kind": "paragraph",
      "text": "CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM",
      "style": "Heading5"
    },
    {
      "blockId": "P0009",
      "kind": "paragraph",
      "text": "Độc lập - Tự do - Hạnh phúc",
      "style": "Heading5"
    },
    {
      "blockId": "P0010",
      "kind": "paragraph",
      "text": "{{document.issuePlaceDateLine}}",
      "style": null
    },
    {
      "blockId": "P0013",
      "kind": "paragraph",
      "text": "BIÊN BẢN",
      "style": null
    },
    {
      "blockId": "P0014",
      "kind": "paragraph",
      "text": "Tiếp nhận nguồn tin về tội phạm",
      "style": null
    },
    {
      "blockId": "P0015",
      "kind": "paragraph",
      "text": "Hồi {{reception.startedAtTimeText}}, ngày {{reception.startedAtDay}} tháng {{reception.startedAtMonth}} năm {{reception.startedAtYear}}, tại {{reception.locationName}}",
      "style": null
    },
    {
      "blockId": "P0016",
      "kind": "paragraph",
      "text": "Tôi: {{receiver.fullName}};\t\tchức danh: {{receiver.positionTitle}}",
      "style": null
    },
    {
      "blockId": "P0017",
      "kind": "paragraph",
      "text": "Đơn vị công tác {{receiver.departmentName}}",
      "style": null
    },
    {
      "blockId": "P0018",
      "kind": "paragraph",
      "text": "Căn cứ các điều 133, 144, 145 và 146 của Bộ luật Tố tụng hình sự, tiến hành tiếp nhận nguồn tin về tội phạm của ông/bà:",
      "style": null
    },
    {
      "blockId": "P0019",
      "kind": "paragraph",
      "text": "Họ tên: {{informant.fullName}}         \t Giới tính: {{informant.genderLabel}}",
      "style": null
    },
    {
      "blockId": "P0020",
      "kind": "paragraph",
      "text": "Tên gọi khác: {{informant.otherName}}",
      "style": null
    },
    {
      "blockId": "P0021",
      "kind": "paragraph",
      "text": "Sinh ngày {{informant.birthDay}} tháng {{informant.birthMonth}} năm {{informant.birthYear}} tại: {{informant.placeOfBirth}}",
      "style": null
    },
    {
      "blockId": "P0022",
      "kind": "paragraph",
      "text": "Quốc tịch: {{informant.nationality}};      Dân tộc: {{informant.ethnicity}};      Tôn giáo: {{informant.religion}}",
      "style": null
    },
    {
      "blockId": "P0023",
      "kind": "paragraph",
      "text": "Nghề nghiệp: {{informant.occupation}}",
      "style": null
    },
    {
      "blockId": "P0024",
      "kind": "paragraph",
      "text": "Số CMND/Thẻ CCCD/Thẻ CC/Hộ chiếu: {{informant.identityNo}}",
      "style": null
    },
    {
      "blockId": "P0025",
      "kind": "paragraph",
      "text": "Cấp ngày {{informant.identityIssuedDay}} tháng {{informant.identityIssuedMonth}} năm {{informant.identityIssuedYear}} Nơi cấp: {{informant.identityIssuedPlace}}",
      "style": null
    },
    {
      "blockId": "P0026",
      "kind": "paragraph",
      "text": "Nơi thường trú: {{informant.permanentAddress}}",
      "style": null
    },
    {
      "blockId": "P0027",
      "kind": "paragraph",
      "text": "Nơi tạm trú: {{informant.temporaryAddress}}",
      "style": null
    },
    {
      "blockId": "P0028",
      "kind": "paragraph",
      "text": "Nơi ở hiện tại: {{informant.currentAddress}}",
      "style": null
    },
    {
      "blockId": "P0029",
      "kind": "paragraph",
      "text": "Số điện thoại: {{informant.phone}}",
      "style": null
    },
    {
      "blockId": "P0030",
      "kind": "paragraph",
      "text": "Là người đại diện của cơ quan, tổ chức (nếu có): {{informant.representedOrganization}}",
      "style": null
    },
    {
      "blockId": "P0031",
      "kind": "paragraph",
      "text": "I. NỘI DUNG NGUỒN TIN VỀ TỘI PHẠM: {{crimeReport.content}}",
      "style": null
    },
    {
      "blockId": "P0032",
      "kind": "paragraph",
      "text": "II. CÁC TÀI LIỆU, ĐỒ VẬT GIAO NỘP KÈM THEO  (nếu có): {{crimeReport.attachedItemsDescription}}",
      "style": null
    },
    {
      "blockId": "P0033",
      "kind": "paragraph",
      "text": "Ngoài nguồn tin về tội phạm và tài liệu, đồ vật có liên quan đã nhận nêu trên chúng tôi không giao, nhận thêm bất cứ tài liệu, đồ vật nào khác.",
      "style": null
    },
    {
      "blockId": "P0034",
      "kind": "paragraph",
      "text": "Việc tiếp nhận nguồn tin về tội phạm kết thúc hồi {{reception.endedAtTimeText}} ngày {{reception.endedAtDay}} tháng {{reception.endedAtMonth}} năm {{reception.endedAtYear}}.",
      "style": null
    },
    {
      "blockId": "P0035",
      "kind": "paragraph",
      "text": "Biên bản này đã được đọc lại cho những người có tên trên nghe, công nhận đúng và cùng ký tên xác nhận dưới dây. Biên bản này được lập thành 02 bản, mỗi bên giữ 01 bản./.",
      "style": null
    },
    {
      "blockId": "P0037",
      "kind": "paragraph",
      "text": "NGƯỜI CUNG CẤP NGUỒN TIN VỀ TỘI PHẠM",
      "style": null
    },
    {
      "blockId": "P0041",
      "kind": "paragraph",
      "text": "{{informant.signerName}}",
      "style": null
    },
    {
      "blockId": "P0042",
      "kind": "paragraph",
      "text": "NGƯỜI TIẾP NHẬN",
      "style": null
    },
    {
      "blockId": "P0047",
      "kind": "paragraph",
      "text": "{{receiver.signerName}}",
      "style": null
    },
    {
      "blockId": "P0048",
      "kind": "paragraph",
      "text": "{{recipients.archiveLine}}",
      "style": null
    }
  ],
