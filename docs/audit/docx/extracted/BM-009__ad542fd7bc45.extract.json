      "text": ".................................................................................................",
      "style": null
    },
    {
      "blockId": "P0022",
      "kind": "paragraph",
      "text": "Nhận thấy việc gia hạn thời hạn giải quyết nguồn tin về tội phạm là có căn cứ,",
      "style": null
    },
    {
      "blockId": "P0023",
      "kind": "paragraph",
      "text": "QUYẾT ĐỊNH:",
      "style": null
    },
    {
      "blockId": "P0024",
      "kind": "paragraph",
      "text": "Điều 1. Gia hạn thời hạn giải quyết nguồn tin về tội phạm5 trong thời hạn",
      "style": null
    },
    {
      "blockId": "P0025",
