      "style": null
    },
    {
      "blockId": "P0048",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0049",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0050",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0051",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0052",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh, thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0053",
      "kind": "paragraph",
      "text": "Trường hợp hủy bỏ trong giai đoạn truy tố thì căn cứ Điều 236 và Điều 241 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0054",
      "kind": "paragraph",
      "text": "Chỉ ghi căn cứ này trong trường hợp bị can là người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0055",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định về việc đặt tiền để bảo đảm",
      "style": null
    },
    {
      "blockId": "P0056",
      "kind": "paragraph",
      "text": "Ghi họ tên bị can",
      "style": null
    },
    {
      "blockId": "P0057",
      "kind": "paragraph",
      "text": "Nêu lý do hủy bỏ biện pháp đặt tiền để bảo đảm (Điều 122 và Điều 125 của Bộ luật Tố tụng hình sự)",
      "style": null
    },
    {
      "blockId": "P0058",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, tổ chức, cá nhân có liên quan",
      "style": null
    },
    {
