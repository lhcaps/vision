    {
      "blockId": "P0013",
      "kind": "paragraph",
      "text": "VIỆN TRƯỞNG VIỆN KIỂM SÁT2",
      "style": null
    },
    {
      "blockId": "P0014",
      "kind": "paragraph",
      "text": "Căn cứ các điều 41, 90 và 106 của Bộ luật Tố tụng hình sự;",
      "style": null
    },
    {
      "blockId": "P0015",
      "kind": "paragraph",
      "text": "Căn cứ Cáo trạng/Quyết định truy tố theo thủ tục rút gọn số",
      "style": null
    },
    {
      "blockId": "P0016",
      "kind": "paragraph",
      "text": "ngày",
      "style": null
    },
    {
      "blockId": "P0017",
