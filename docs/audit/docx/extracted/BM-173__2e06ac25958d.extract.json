      "style": null
    },
    {
      "blockId": "P0019",
      "kind": "paragraph",
      "text": "của Viện kiểm sát2",
      "style": null
    },
    {
      "blockId": "P0020",
      "kind": "paragraph",
      "text": "Xét thấy cần phải chuyển các vật chứng của vụ án",
      "style": null
    },
    {
      "blockId": "P0021",
      "kind": "paragraph",
      "text": "đến",
      "style": null
    },
    {
      "blockId": "P0022",
      "kind": "paragraph",
      "text": "để bảo đảm việc xét xử và thi hành án theo quy định của pháp luật,",
      "style": null
    },
    {
      "blockId": "P0023",
      "kind": "paragraph",
      "text": "QUYẾT ĐỊNH:",
      "style": null
    },
    {
      "blockId": "P0024",
      "kind": "paragraph",
      "text": "Điều 1. Chuyển các vật chứng sau đây",
      "style": null
    },
    {
      "blockId": "P0025",
      "kind": "paragraph",
      "text": "đến6",
      "style": null
    },
    {
      "blockId": "P0026",
      "kind": "paragraph",
      "text": "Điều 2. Yêu cầu6 và 8 ... thực hiện việc giao, nhận vật chứng và gửi 02 biên bản giao, nhận đến Viện kiểm sát2",
      "style": null
    },
    {
      "blockId": "P0027",
      "kind": "paragraph",
      "text": "Nơi nhận:",
      "style": null
    },
    {
      "blockId": "P0028",
      "kind": "paragraph",
      "text": "- 6...;",
      "style": null
    },
    {
      "blockId": "P0029",
      "kind": "paragraph",
      "text": "- 8...;",
      "style": null
    },
    {
      "blockId": "P0030",
      "kind": "paragraph",
      "text": "- Lưu: HSVA, HSKS,",
      "style": null
    },
    {
      "blockId": "P0031",
      "kind": "paragraph",
      "text": "VP.",
      "style": null
    },
    {
      "blockId": "P0032",
      "kind": "paragraph",
      "text": "..................................................",
      "style": null
    },
    {
      "blockId": "P0033",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0034",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0035",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0036",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0037",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0038",
      "kind": "paragraph",
      "text": "Ghi rõ vụ án theo Quyết định khởi tố số",
      "style": null
    },
    {
      "blockId": "P0039",
      "kind": "paragraph",
      "text": "ngày",
      "style": null
    },
    {
      "blockId": "P0040",
      "kind": "paragraph",
      "text": "tháng",
      "style": null
    },
    {
      "blockId": "P0041",
      "kind": "paragraph",
      "text": "năm",
      "style": null
    },
    {
      "blockId": "P0042",
      "kind": "paragraph",
      "text": "của",
      "style": null
    },
    {
      "blockId": "P0043",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan thi hành án có thẩm quyền",
      "style": null
    },
    {
      "blockId": "P0044",
      "kind": "paragraph",
      "text": "Ghi rõ vật chứng cần chuyển, trường hợp nhiều vật chứng thì lập bảng thống kê kèm theo",
      "style": null
    },
    {
      "blockId": "P0045",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền điều tra đang quản lý vật chứng",
      "style": null
    },
    {
      "blockId": "P0046",
      "kind": "paragraph",
      "text": "Ghi chức danh người ký",
      "style": null
    },
    {
      "blockId": "P0047",
      "kind": "paragraph",
      "text": "Mẫu số 173/HS",
      "style": null
