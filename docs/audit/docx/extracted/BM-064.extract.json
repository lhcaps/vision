    {
      "blockId": "P0025",
      "kind": "paragraph",
      "text": "Điều 1. Hủy bỏ biện pháp kê biên tài sản theo Lệnh kê biên tài sản số",
      "style": null
    },
    {
      "blockId": "P0026",
