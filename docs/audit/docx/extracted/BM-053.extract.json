    {
      "blockId": "P0083",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0084",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0085",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh, thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0086",
      "kind": "paragraph",
      "text": "Trường hợp ra Lệnh cấm đi khỏi nơi cư trú trong giai đoạn truy tố thì căn cứ Điều 236 và Điều 241 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0087",
      "kind": "paragraph",
      "text": "Chỉ ghi căn cứ này trong trường hợp bị can là người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0088",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0089",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố bị can",
