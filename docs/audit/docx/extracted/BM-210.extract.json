    {
      "blockId": "P0059",
      "kind": "paragraph",
      "text": "phải kịp thời thông báo cho Ủy ban nhân dân11",
      "style": null
    },
    {
      "blockId": "P0060",
      "kind": "paragraph",
      "text": "về việc vi phạm và phối hợp với cơ quan có thẩm quyền để có biện pháp ngăn chặn, xử lý kịp thời. Ủy ban nhân dân11",
      "style": null
