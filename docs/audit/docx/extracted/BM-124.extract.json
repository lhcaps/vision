    {
      "blockId": "P0035",
      "kind": "paragraph",
      "text": "Biên bản này lập thành 02 bản, lưu hồ sơ vụ án và hồ sơ kiểm sát.",
      "style": null
    },
    {
      "blockId": "P0036",
      "kind": "paragraph",
      "text": "Biên bản này đã đọc cho những người có tên nêu trên nghe, công nhận là đúng và cùng ký tên xác nhận dưới đây./.",
      "style": null
    },
    {
