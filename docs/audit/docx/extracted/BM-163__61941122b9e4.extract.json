      "text": "năm",
      "style": null
    },
    {
      "blockId": "P0021",
      "kind": "paragraph",
      "text": "có mặt tại",
      "style": null
    },
    {
      "blockId": "P0022",
      "kind": "paragraph",
      "text": "Khi đến mang theo Giấy triệu tập này, CMND/Thẻ CCCD/Thẻ CC/Hộ chiếu hoặc giấy tờ tùy thân khác và gặp",
      "style": null
    },
    {
      "blockId": "P0023",
      "kind": "paragraph",
      "text": ", số điện thoại",
      "style": null
    },
    {
      "blockId": "P0024",
      "kind": "paragraph",
      "text": "Yêu cầu6",
      "style": null
    },
    {
      "blockId": "P0025",
      "kind": "paragraph",
      "text": "có mặt theo đúng thời gian và địa điểm nêu trên./.",
      "style": null
    },
    {
      "blockId": "P0026",
      "kind": "paragraph",
      "text": "Nơi nhận:",
      "style": null
    },
    {
      "blockId": "P0027",
      "kind": "paragraph",
      "text": "- Lưu: HSVV/VA, HSKS, VP.",
      "style": null
    },
    {
      "blockId": "P0028",
      "kind": "paragraph",
      "text": "KIỂM SÁT VIÊN",
      "style": null
    },
    {
      "blockId": "P0029",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0030",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0031",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0032",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0033",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0034",
      "kind": "paragraph",
      "text": "Mẫu này dùng trong trường hợp triệu tập và hỏi cung bị can; triệu tập và lấy lời khai người tố giác, báo tin về",
      "style": null
    },
    {
      "blockId": "P0035",
      "kind": "paragraph",
      "text": "tội phạm, người bị tố giác, người bị kiến nghị khởi tố, người đại diện theo pháp luật của pháp nhân, người làm chứng, bị hại, đương sự",
      "style": null
    },
    {
      "blockId": "P0036",
      "kind": "paragraph",
      "text": "Ghi họ tên người được triệu tập; trường hợp triệu tập cơ quan, tổ chức, pháp nhân thì ghi đầy đủ thông tin của cơ quan, tổ chức, pháp nhân (gồm: tên, địa chỉ đặt trụ sở chính; số đăng ký kinh doanh, quốc tịch, họ tên người đại diện theo pháp luật (nếu có),",
      "style": null
    },
    {
      "blockId": "P0037",
      "kind": "paragraph",
      "text": "Ghi rõ tư cách tham gia tố tụng",
      "style": null
    },
    {
      "blockId": "P0038",
      "kind": "paragraph",
      "text": "Ghi tóm tắt nội dung vụ việc; trường hợp vụ án thì ghi rõ khởi tố theo theo Quyết định khởi tố vụ án hình sự số",
      "style": null
    },
    {
      "blockId": "P0039",
      "kind": "paragraph",
      "text": "ngày",
      "style": null
    },
    {
      "blockId": "P0040",
      "kind": "paragraph",
      "text": "tháng",
      "style": null
    },
    {
      "blockId": "P0041",
      "kind": "paragraph",
      "text": "năm",
      "style": null
    },
    {
      "blockId": "P0042",
      "kind": "paragraph",
      "text": "của",
      "style": null
    },
    {
      "blockId": "P0043",
      "kind": "paragraph",
      "text": "Ghi rõ tên, địa chỉ nơi tiến hành hoạt động tố tụng",
      "style": null
    },
    {
      "blockId": "P0044",
      "kind": "paragraph",
      "text": "Ghi rõ lý do triệu tập",
      "style": null
    },
    {
      "blockId": "P0045",
      "kind": "paragraph",
      "text": "Ghi họ tên, chức danh người được phân công làm việc với người được mời",
      "style": null
    },
    {
      "blockId": "P0046",
      "kind": "paragraph",
      "text": "Mẫu số 163/HS",
      "style": null
