    {
      "blockId": "P0042",
      "kind": "paragraph",
      "text": "Điều 2. Yêu cầu Tổ chức tín dụng/Kho bạc Nhà nước11",
      "style": null
    },
    {
      "blockId": "P0043",
      "kind": "paragraph",
      "text": "đang quản lý tài khoản bị phong tỏa tiến hành giải tỏa tài khoản trên ngay khi nhận được Quyết định này./.",
      "style": null
    },
    {
      "blockId": "P0044",
      "kind": "paragraph",
      "text": "Nơi nhận:",
      "style": null
    },
    {
