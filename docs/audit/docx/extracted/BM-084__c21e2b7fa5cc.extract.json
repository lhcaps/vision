      "style": null
    },
    {
      "blockId": "P0013",
      "kind": "paragraph",
      "text": "VIỆN TRƯỞNG VIỆN KIỂM SÁT2...",
      "style": null
    },
    {
      "blockId": "P0014",
      "kind": "paragraph",
      "text": "Căn cứ Điều 41 và Điều 68/69 của Bộ luật Tố tụng hình sự;",
      "style": null
    },
    {
      "blockId": "P0015",
      "kind": "paragraph",
      "text": "Căn cứ Quyết định trưng cầu giám định/Yêu cầu định giá tài sản số",
      "style": null
    },
    {
      "blockId": "P0016",
