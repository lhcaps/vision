    },
    {
      "blockId": "P0071",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0072",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0073",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0074",
      "kind": "paragraph",
      "text": "Trường hợp Quyết định đình chỉ vụ án đối với bị can là pháp nhân thì bổ sung căn cứ Điều 443 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0075",
      "kind": "paragraph",
      "text": "Chỉ ghi căn cứ này trong trường hợp vụ án có bị can là người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0076",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0077",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố bị can",
      "style": null
    },
    {
      "blockId": "P0078",
      "kind": "paragraph",
      "text": "Ghi họ tên người hoặc tên pháp nhân bị khởi tố",
      "style": null
    },
    {
      "blockId": "P0079",
      "kind": "paragraph",
      "text": "10 Ghi lý do, căn cứ đình chỉ vụ án hình sự đối với bị can theo quy định tại khoản 1 Điều 248 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0080",
      "kind": "paragraph",
      "text": "11 Trường hợp đình chỉ vụ án hình sự đối với bị can là pháp nhân thì ghi đầy đủ thông tin về pháp nhân (gồm: tên pháp nhân, địa chỉ đặt trụ sở chính, số đăng ký kinh doanh, quốc tịch, họ tên người đại diện theo pháp luật,",
      "style": null
    },
    {
      "blockId": "P0081",
      "kind": "paragraph",
      "text": "12 Ghi rõ vật chứng, tài liệu, đồ vật đã tạm giữ, các vấn đề khác có liên quan (nếu có)",
      "style": null
    },
    {
      "blockId": "P0082",
      "kind": "paragraph",
      "text": "13 Ghi tên cơ quan, tổ chức, cá nhân có liên quan",
      "style": null
    },
