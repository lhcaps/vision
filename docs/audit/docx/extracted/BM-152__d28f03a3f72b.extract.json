      "style": null
    },
    {
      "blockId": "P0068",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0069",
      "kind": "paragraph",
      "text": "14 Ghi chức danh người ký",
      "style": null
    },
    {
      "blockId": "P0070",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
