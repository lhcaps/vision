    {
      "blockId": "P0036",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0037",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0038",
      "kind": "paragraph",
      "text": "Tùy từng trường hợp thì ghi Thủ trưởng, Cấp trưởng, Phó Thủ trưởng, Cấp phó, Điều tra viên, cán bộ điều tra",
      "style": null
    },
    {
      "blockId": "P0039",
      "kind": "paragraph",
      "text": "Trường hợp yêu cầu thay đổi Thủ trưởng, Cấp trưởng, Phó Thủ trưởng, Cấp phó, Điều tra viên, cán bộ điều tra trong giai đoạn điều tra thì căn cứ Điều 166 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0040",
      "kind": "paragraph",
      "text": "Ghi cơ quan, người có thẩm quyền ra Quyết định phân công",
      "style": null
    },
    {
      "blockId": "P0041",
      "kind": "paragraph",
      "text": "Ghi rõ lý do yêu cầu thay đổi theo quy định tại Điều 51 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0042",
      "kind": "paragraph",
      "text": "Hoặc Cấp trưởng",
      "style": null
    },
    {
      "blockId": "P0043",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan ra Quyết định thay đổi",
      "style": null
    },
    {
      "blockId": "P0044",
      "kind": "paragraph",
      "text": "Trong trường hợp yêu cầu Điều tra viên là Trưởng/Phó trưởng Công an cấp xã",
      "style": null
    },
    {
      "blockId": "P0045",
      "kind": "paragraph",
      "text": "Ghi họ tên, chức danh người bị thay đổi",
      "style": null
    },
    {
      "blockId": "P0046",
      "kind": "paragraph",
      "text": "Ghi rõ nhiệm vụ giải quyết vụ việc/điều tra vụ án nào",
      "style": null
    },
    {
      "blockId": "P0047",
