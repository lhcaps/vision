    },
    {
      "blockId": "P0061",
      "kind": "paragraph",
      "text": "Điều 2. Yêu cầu 12 và 14... thi hành Lệnh này theo quy định của Bộ luật Tố tụng hình sự.",
      "style": null
    },
    {
      "blockId": "P0062",
      "kind": "paragraph",
      "text": "Phân công Kiểm sát viên ... tổ chức thi hành Lệnh này",
      "style": null
    },
    {
      "blockId": "P0063",
      "kind": "paragraph",
      "text": "Ngay sau khi nhận được Lệnh phong tỏa tài khoản, Tổ chức tín dụng/Kho bạc Nhà nước",
      "style": null
    },
    {
      "blockId": "P0064",
      "kind": "paragraph",
      "text": "đang quản lý tài khoản của người bị bắt, người bị tạm giữ, bị can hoặc tài khoản của người khác có liên quan đến hành vi phạm tội của người bị buộc tội phải thực hiện ngay việc phong tỏa tài khoản và có trách nhiệm quản lý cho đến khi có quyết định của cơ quan, người có thẩm quyền tiến hành tố tụng. Nếu người được giao thực hiện Lệnh phong tỏa, quản lý tài khoản bị phong tỏa mà giải tỏa việc phong tỏa khi chưa có quyết định của cơ quan, người có thẩm quyền ra Lệnh phong tỏa tài khoản thì phải chịu trách nhiệm theo quy định của pháp luật./.",
      "style": null
    },
    {
      "blockId": "P0065",
      "kind": "paragraph",
      "text": "Nơi nhận:",
      "style": null
    },
    {
      "blockId": "P0066",
      "kind": "paragraph",
      "text": "- 12",
      "style": null
    },
    {
      "blockId": "P0067",
      "kind": "paragraph",
      "text": "- Cơ quan, người có thẩm quyền",
      "style": null
    },
    {
      "blockId": "P0068",
      "kind": "paragraph",
      "text": "điều tra;",
      "style": null
    },
    {
      "blockId": "P0069",
      "kind": "paragraph",
      "text": "- Cơ quan, tổ chức, cá nhân liên quan;",
      "style": null
    },
    {
      "blockId": "P0070",
      "kind": "paragraph",
      "text": "- Lưu: HSVA, HSKS, VP.",
      "style": null
    },
    {
      "blockId": "P0071",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0072",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0073",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0074",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0075",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0076",
      "kind": "paragraph",
      "text": "Lệnh này được áp dụng đối với người bị buộc tội hoặc người khác liên quan đến hành vi phạm tội của người bị buộc tội",
      "style": null
    },
    {
      "blockId": "P0077",
      "kind": "paragraph",
      "text": "Trường hợp ra Lệnh phong tỏa tài khoản trong giai đoạn truy tố thì căn cứ Điều 236 và Điều 241 của Bộ luật Tố tụng hình sự; trường hợp ra Lệnh phong tỏa tài khoản đối với pháp nhân thì bổ sung căn cứ Điều 436 và Điều 438 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0078",
      "kind": "paragraph",
      "text": "Chỉ ghi căn cứ này trong trường hợp người bị phong tỏa tài khoản là người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0079",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0080",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố bị can",
      "style": null
    },
    {
      "blockId": "P0081",
      "kind": "paragraph",
      "text": "Ghi họ tên bị can, tên pháp nhân bị khởi tố",
      "style": null
    },
    {
      "blockId": "P0082",
      "kind": "paragraph",
      "text": "Ghi căn cứ và lý do cần áp dụng biện pháp phong tỏa tài khoản theo quy định tại Điều 129 và Điều 438 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0083",
      "kind": "paragraph",
      "text": "Ghi họ tên người có tài khoản bị phong tỏa; trường hợp phong tỏa tài khoản của pháp nhân thì ghi đầy đủ thông tin về pháp nhân (gồm: tên pháp nhân, địa chỉ đặt trụ sở chính, số đăng ký kinh doanh, quốc tịch, họ tên người đại diện theo pháp luật,",
      "style": null
    },
    {
      "blockId": "P0084",
      "kind": "paragraph",
      "text": "Nội dung phân công Kiểm sát viên chỉ ghi trong trường hợp phong tỏa tài khoản trong giai đoạn truy tố; trường hợp Viện kiểm sát ra Lệnh trong giai đoạn khởi tố, điều tra thì Viện kiểm sát chuyển lệnh cho cơ quan, người có thẩm quyền điều tra để tổ chức thực hiện",
      "style": null
    },
    {
      "blockId": "P0085",
      "kind": "paragraph",
      "text": "Ghi rõ Tổ chức tín dụng/Kho bạc Nhà nước đang quản lý tài khoản bị phong tỏa",
      "style": null
    },
    {
      "blockId": "P0086",
      "kind": "paragraph",
      "text": "15 Ghi chức danh người ký",
      "style": null
    },
    {
