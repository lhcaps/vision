      "style": null
    },
    {
      "blockId": "P0055",
      "kind": "paragraph",
      "text": "Nơi ở hiện tại:",
      "style": null
    },
    {
      "blockId": "P0056",
      "kind": "paragraph",
      "text": "Điều 2. Yêu cầu12... và13... thi hành Lệnh này theo quy định của Bộ luật Tố tụng hình sự.",
      "style": null
    },
    {
      "blockId": "P0057",
      "kind": "paragraph",
      "text": "Phân công Kiểm sát viên",
      "style": null
    },
    {
      "blockId": "P0058",
      "kind": "paragraph",
      "text": "tổ chức thi hành Lệnh này14.",
      "style": null
    },
    {
      "blockId": "P0059",
      "kind": "paragraph",
      "text": "Điều 3. Tài sản kê biên giao cho15",
      "style": null
    },
    {
      "blockId": "P0060",
      "kind": "paragraph",
      "text": "có trách nhiệm",
      "style": null
    },
    {
      "blockId": "P0061",
      "kind": "paragraph",
      "text": "bảo quản cho đến khi có quyết định của cơ quan có thẩm quyền. Nếu có hành vi tiêu dùng, chuyển nhượng, đánh tráo, cất giấu hoặc hủy hoại tài sản bị kê biên thì phải chịu trách nhiệm theo quy định của Bộ luật Hình sự./.",
      "style": null
    },
    {
      "blockId": "P0062",
      "kind": "paragraph",
      "text": "Nơi nhận:",
      "style": null
    },
    {
      "blockId": "P0063",
      "kind": "paragraph",
      "text": "- 12",
      "style": null
    },
    {
      "blockId": "P0064",
      "kind": "paragraph",
      "text": "- 13",
      "style": null
    },
    {
      "blockId": "P0065",
      "kind": "paragraph",
      "text": "- 15",
      "style": null
    },
    {
      "blockId": "P0066",
      "kind": "paragraph",
      "text": "- Lưu: HSVA, HSKS, VP.",
      "style": null
    },
    {
      "blockId": "P0067",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0068",
      "kind": "paragraph",
      "text": "14 Nội dung phân công Kiểm sát viên chỉ ghi trong trường hợp kê biên tài sản trong giai đoạn truy tố",
      "style": null
    },
    {
      "blockId": "P0069",
      "kind": "paragraph",
      "text": "15 Ghi rõ: chủ tài sản, người quản lý hợp pháp hoặc người thân thích của bị can",
      "style": null
    },
    {
      "blockId": "P0070",
      "kind": "paragraph",
      "text": "16 Ghi chức danh người ký",
      "style": null
    },
    {
      "blockId": "P0071",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0072",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0073",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0074",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0075",
      "kind": "paragraph",
      "text": "Trường hợp ra Lệnh kê biên tài sản trong giai đoạn truy tố thì căn cứ Điều 236 và Điều 241 của Bộ luật Tố tụng hình sự; trường hợp ra Lệnh kê biên tài sản của pháp nhân thì bổ sung căn cứ Điều 436 và Điều 437 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0076",
      "kind": "paragraph",
      "text": "Chỉ ghi căn cứ này trong trường hợp người bị kê biên là người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0077",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0078",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố bị can",
      "style": null
    },
    {
      "blockId": "P0079",
      "kind": "paragraph",
      "text": "Ghi họ tên bị can, tên pháp nhân bị khởi tố",
      "style": null
    },
    {
      "blockId": "P0080",
      "kind": "paragraph",
      "text": "Nêu lý do, căn cứ kê biên tài sản theo quy định tại Điều 128 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0081",
      "kind": "paragraph",
      "text": "11 Liệt kê tài sản bị kê biên; trường hợp tài sản có đăng ký quyền sở hữu, quyền sử dụng thì cần phải ghi rõ giấy chứng nhận số",
      "style": null
    },
    {
      "blockId": "P0082",
      "kind": "paragraph",
      "text": "ngày",
      "style": null
    },
    {
      "blockId": "P0083",
      "kind": "paragraph",
      "text": "nơi cấp",
      "style": null
    },
    {
      "blockId": "P0084",
      "kind": "paragraph",
      "text": "người được cấp",
      "style": null
    },
    {
      "blockId": "P0085",
      "kind": "paragraph",
      "text": "12 Ghi họ tên người có tài sản bị kê biên; trường hợp kê biên tài sản của pháp nhân thì ghi đầy đủ thông tin về pháp nhân (gồm: tên pháp nhân, địa chỉ đặt trụ sở chính, số đăng ký kinh doanh, quốc tịch, họ tên người đại diện theo pháp luật,",
      "style": null
    },
    {
      "blockId": "P0086",
      "kind": "paragraph",
      "text": "13 Ghi tên cơ quan, người có trách nhiệm thi hành Lệnh kê biên tài sản; cơ quan, tổ chức, cá nhân có liên quan",
      "style": null
    },
    {
      "blockId": "P0087",
      "kind": "paragraph",
      "text": "Mẫu số 62/HS",
      "style": null
    },
    {
      "blockId": "P0088",
      "kind": "paragraph",
      "text": "(Ban hành theo Thông tư số      /2026/TT-VKSTC",
      "style": null
    },
    {
      "blockId": "P0089",
      "kind": "paragraph",
      "text": "ngày       /     /2026)",
      "style": null
    }
