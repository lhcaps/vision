      "style": null
    },
    {
      "blockId": "P0044",
      "kind": "paragraph",
      "text": "KIỂM SÁT VIÊN",
      "style": null
    },
    {
      "blockId": "P0045",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0046",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0047",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0048",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0049",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0050",
      "kind": "paragraph",
      "text": "Mẫu này dùng trong trường hợp thông báo cho người đại diện/người bảo vệ quyền và lợi ích hợp pháp của người chưa thành niên là bị hại hoặc thông báo cho người đại diện của người chưa thành niên là người làm chứng biết về việc thụ lý vụ án hoặc biết về việc tiến hành hoạt động tố tụng để tham gia",
      "style": null
    },
    {
      "blockId": "P0051",
      "kind": "paragraph",
      "text": "Ghi họ tên người được thông báo",
      "style": null
    },
    {
      "blockId": "P0052",
      "kind": "paragraph",
      "text": "Ghi rõ người đại diện/người bảo vệ quyền và lợi ích hợp pháp",
      "style": null
    },
    {
      "blockId": "P0053",
      "kind": "paragraph",
      "text": "Ghi họ tên người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0054",
      "kind": "paragraph",
      "text": "Ghi rõ tư cách tham gia tố tụng",
      "style": null
    },
    {
      "blockId": "P0055",
      "kind": "paragraph",
      "text": "Ghi tóm tắt nội dung vụ việc; trường hợp vụ án thì ghi rõ khởi tố theo Quyết định khởi tố vụ án hình sự số",
      "style": null
    },
    {
      "blockId": "P0056",
      "kind": "paragraph",
      "text": "ngày",
      "style": null
    },
    {
      "blockId": "P0057",
      "kind": "paragraph",
      "text": "tháng",
      "style": null
    },
    {
      "blockId": "P0058",
      "kind": "paragraph",
      "text": "năm",
      "style": null
    },
    {
      "blockId": "P0059",
      "kind": "paragraph",
      "text": "của",
      "style": null
    },
    {
      "blockId": "P0060",
      "kind": "paragraph",
      "text": "Ghi rõ hoạt động tố tụng",
      "style": null
    },
    {
      "blockId": "P0061",
      "kind": "paragraph",
      "text": "Trường hợp thông báo về việc thụ lý vụ án thì ghi:",
      "style": null
    },
    {
      "blockId": "P0062",
      "kind": "paragraph",
      "text": "Để tham gia tố tụng theo quy định của Bộ luật Tố tụng hình sự và Luật Tư pháp người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0063",
      "kind": "paragraph",
      "text": "Ghi họ tên, chức danh người tiến hành hoạt động tố tụng",
      "style": null
    },
    {
