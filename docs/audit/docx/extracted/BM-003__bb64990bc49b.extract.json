    {
      "blockId": "P0032",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0033",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0034",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0035",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0036",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0037",
      "kind": "paragraph",
      "text": "Ghi rõ nguồn tin về tội phạm là tố giác hoặc tin báo về tội phạm hoặc kiến nghị khởi tố hoặc nguồn tin về tội phạm khác",
      "style": null
    },
    {
      "blockId": "P0038",
      "kind": "paragraph",
      "text": "Ghi họ tên người được phân công; trường hợp phân công nhiều Kiểm sát viên thì ghi rõ Kiểm sát viên thụ lý chính",
      "style": null
    },
    {
      "blockId": "P0039",
      "kind": "paragraph",
      "text": "Ghi rõ chức danh người được phân công",
      "style": null
    },
    {
      "blockId": "P0040",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền giải quyết nguồn tin về tội phạm",
      "style": null
    },
    {
      "blockId": "P0041",
      "kind": "paragraph",
      "text": "Trích dẫn ngắn gọn nội dung vụ việc (nguồn cung cấp, thời gian, địa điểm, hành vi có dấu hiệu tội phạm,",
      "style": null
    },
    {
      "blockId": "P0042",
      "kind": "paragraph",
      "text": "Ghi họ tên Kiểm tra viên được phân công",
      "style": null
    },
    {
      "blockId": "P0043",
      "kind": "paragraph",
      "text": "Ghi rõ Kiểm tra viên, Kiểm tra viên chính, Kiểm tra viên cao cấp",
