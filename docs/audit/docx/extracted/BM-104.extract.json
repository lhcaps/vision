      "style": null
    },
    {
      "blockId": "P0056",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0057",
      "kind": "paragraph",
      "text": "Ghi rõ lần gia hạn; trường hợp gia hạn đối với vụ án phục hồi điều tra thì không cần ghi mục này; trường hợp gia hạn lần thứ 2 trở đi phải ghi rõ căn cứ gia hạn lần liền kề trước đó",
      "style": null
    },
    {
      "blockId": "P0058",
      "kind": "paragraph",
      "text": "Trường hợp vụ án phục hồi điều tra thì bổ sung căn cứ Điều 174 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0059",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0060",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định phục hồi điều tra vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0061",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền đề nghị gia hạn thời hạn điều tra vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0062",
      "kind": "paragraph",
      "text": "10 Trường hợp gia hạn theo khoản 3 Điều 172 của Bộ luật Tố tụng hình sự thì ghi là",
      "style": null
    },
    {
      "blockId": "P0063",
      "kind": "paragraph",
      "text": "gia hạn trong trường hợp đặc biệt",
      "style": null
    },
    {
      "blockId": "P0064",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền điều tra. Trường hợp Viện kiểm sát cấp trên gia hạn điều tra theo đề nghị của Viện kiểm sát cấp dưới thì ghi tên cơ quan có thẩm quyền điều tra và Viện kiểm sát đã đề nghị gia hạn thời hạn điều tra vụ án hình sự",
      "style": null
