      "text": "(Ký, ghi rõ họ tên)",
      "style": null
    },
    {
      "blockId": "P0063",
      "kind": "paragraph",
      "text": "ĐẠI DIỆN ỦY BAN NHÂN DÂN CẤP XÃ",
      "style": null
    },
    {
      "blockId": "P0064",
      "kind": "paragraph",
