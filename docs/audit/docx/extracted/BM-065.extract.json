    {
      "blockId": "P0044",
      "kind": "paragraph",
      "text": "phải thực hiện ngay việc hủy bỏ biện pháp kê biên tài sản.",
      "style": null
    },
    {
      "blockId": "P0045",
      "kind": "paragraph",
      "text": "Việc thi hành Quyết định hủy bỏ biện pháp kê biên tài sản kết thúc vào hồi",
      "style": null
    },
    {
      "blockId": "P0046",
