      "style": null
    },
    {
      "blockId": "P0045",
      "kind": "paragraph",
      "text": "của",
      "style": null
    },
    {
      "blockId": "P0046",
      "kind": "paragraph",
      "text": "Trên cơ sở kết quả điều tra và Quyết định đề nghị truy tố số",
      "style": null
    },
    {
      "blockId": "P0047",
      "kind": "paragraph",
      "text": "ngày",
      "style": null
    },
    {
      "blockId": "P0048",
      "kind": "paragraph",
      "text": "tháng",
      "style": null
    },
    {
      "blockId": "P0049",
      "kind": "paragraph",
      "text": "năm",
      "style": null
    },
    {
      "blockId": "P0050",
      "kind": "paragraph",
      "text": "của",
      "style": null
    },
    {
      "blockId": "P0051",
      "kind": "paragraph",
      "text": ", xác định được như sau:",
      "style": null
    },
    {
      "blockId": "P0052",
      "kind": "paragraph",
      "text": "Vì các lẽ trên,",
      "style": null
    },
    {
      "blockId": "P0053",
      "kind": "paragraph",
      "text": "QUYẾT ĐỊNH:",
      "style": null
    },
    {
      "blockId": "P0054",
      "kind": "paragraph",
      "text": "1. Truy tố ra trước Tòa án",
      "style": null
    },
    {
      "blockId": "P0055",
      "kind": "paragraph",
      "text": "để xét xử về tội",
      "style": null
    },
    {
      "blockId": "P0056",
      "kind": "paragraph",
      "text": "quy định tại điểm",
      "style": null
    },
    {
      "blockId": "P0057",
      "kind": "paragraph",
      "text": "khoản",
      "style": null
    },
    {
      "blockId": "P0058",
      "kind": "paragraph",
      "text": "Điều",
      "style": null
    },
    {
      "blockId": "P0059",
      "kind": "paragraph",
      "text": "của Bộ luật Hình sự đối với bị can7... (hoặc các bị can ...) có lý lịch như sau:",
      "style": null
    },
    {
      "blockId": "P0060",
      "kind": "paragraph",
      "text": "- Nêu lý lịch từng bị can (chú ý sắp xếp theo thứ tự căn cứ vào vai trò của từng bị can), gồm",
      "style": null
    },
    {
      "blockId": "P0061",
      "kind": "paragraph",
      "text": "+ Họ tên, tên gọi khác; giới tính, ngày, tháng, năm sinh, nơi sinh, nơi cư trú, quốc tịch, dân tộc, tôn giáo, trình độ học vấn, nghề nghiệp, chức vụ trước khi phạm tội (Đảng, chính quyền, đoàn thể);",
      "style": null
    },
    {
      "blockId": "P0062",
      "kind": "paragraph",
      "text": "+ Họ tên cha, mẹ (sinh năm, sống hay chết), anh chị em ruột, vợ/chồng, có mấy con, lớn nhất mấy tuổi, nhỏ nhất mấy tuổi;",
      "style": null
    },
    {
      "blockId": "P0063",
      "kind": "paragraph",
      "text": "+ Nếu bị can là thương binh, bệnh binh hoặc có huân, huy chương hoặc các danh hiệu Nhà nước phong tặng khác (cán bộ hoạt động trước Cách mạng tháng 8, anh hùng lao động, anh hùng các lực lượng vũ trang, bà mẹ Việt Nam anh hùng hoặc thân nhân của bị can là thương binh, liệt sỹ) thì cần ghi rõ.",
      "style": null
    },
    {
      "blockId": "P0064",
      "kind": "paragraph",
      "text": "Tiền sự (chỉ ghi tiền sự còn thời hạn xem xét):.............................................................",
      "style": null
    },
    {
      "blockId": "P0065",
      "kind": "paragraph",
      "text": "Tiền án: ghi rõ ngày xét xử, Tòa",
      "style": null
    },
    {
      "blockId": "P0066",
      "kind": "paragraph",
      "text": "án xét xử, tội danh, điểm, khoản, Điều Bộ luật Hình sự, hình phạt (các thông tin về việc thi hành bản án, quyết định của Tòa án) .............................................................................................................................................",
      "style": null
    },
    {
      "blockId": "P0067",
      "kind": "paragraph",
      "text": "Bị can",
      "style": null
    },
    {
      "blockId": "P0068",
      "kind": "paragraph",
      "text": "đang bị áp dụng biện pháp ngăn chặn, biện pháp cưỡng chế",
      "style": null
    },
    {
      "blockId": "P0069",
      "kind": "paragraph",
      "text": "; từ",
      "style": null
    },
    {
      "blockId": "P0070",
      "kind": "paragraph",
      "text": "đến",
      "style": null
    },
    {
      "blockId": "P0071",
      "kind": "paragraph",
      "text": "tại",
      "style": null
    },
    {
      "blockId": "P0072",
      "kind": "paragraph",
      "text": "2. Kèm theo Quyết định này có:",
      "style": null
    },
    {
      "blockId": "P0073",
      "kind": "paragraph",
      "text": "- Hồ sơ vụ án gồm:",
      "style": null
    },
    {
      "blockId": "P0074",
      "kind": "paragraph",
      "text": "tập, bằng",
      "style": null
    },
    {
      "blockId": "P0075",
      "kind": "paragraph",
      "text": "tờ; đánh số thứ tự từ 01 đến",
      "style": null
    },
    {
      "blockId": "P0076",
      "kind": "paragraph",
      "text": "- Bản thống kê vật chứng (nếu có).",
      "style": null
    },
    {
      "blockId": "P0077",
      "kind": "paragraph",
      "text": "- Danh sách những người Viện kiểm sát đề nghị Tòa án triệu tập đến phiên tòa.",
      "style": null
    },
    {
      "blockId": "P0078",
      "kind": "paragraph",
      "text": ".../.",
      "style": null
    },
    {
      "blockId": "P0079",
      "kind": "paragraph",
      "text": "Nơi nhận:",
      "style": null
    },
    {
      "blockId": "P0080",
      "kind": "paragraph",
      "text": "- 11",
      "style": null
    },
    {
      "blockId": "P0081",
      "kind": "paragraph",
      "text": "/người đại diện của bị can;",
      "style": null
    },
    {
      "blockId": "P0082",
      "kind": "paragraph",
      "text": "- Người bào chữa;",
      "style": null
    },
    {
      "blockId": "P0083",
      "kind": "paragraph",
      "text": "- Lưu: HSVA, HSKS, VP.",
      "style": null
    },
    {
      "blockId": "P0084",
      "kind": "paragraph",
      "text": "...............................................",
      "style": null
    },
    {
      "blockId": "P0085",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0086",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0087",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0088",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0089",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0090",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0091",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố bị can",
      "style": null
    },
    {
      "blockId": "P0092",
      "kind": "paragraph",
      "text": "Ghi họ tên người hoặc tên pháp nhân bị khởi tố",
      "style": null
    },
    {
      "blockId": "P0093",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định áp dụng thủ tục rút gọn",
      "style": null
    },
    {
      "blockId": "P0094",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định đề nghị truy tố",
      "style": null
    },
    {
      "blockId": "P0095",
      "kind": "paragraph",
      "text": "Ghi nội dung Quyết định truy tố theo quy định tại khoản 2 Điều 461 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0096",
      "kind": "paragraph",
      "text": "Ghi tên Tòa án có thẩm quyền xét xử",
      "style": null
    },
    {
      "blockId": "P0097",
      "kind": "paragraph",
      "text": "Trường hợp truy tố bị can là pháp nhân thì ghi đầy đủ thông tin về pháp nhân (gồm: tên pháp nhân, địa chỉ đặt trụ sở chính, số đăng ký kinh doanh, quốc tịch, họ tên người đại diện theo pháp luật,",
      "style": null
    },
    {
      "blockId": "P0098",
      "kind": "paragraph",
      "text": "Ghi chức danh người ký",
      "style": null
    },
    {
      "blockId": "P0099",
      "kind": "paragraph",
      "text": "Mẫu số 183/HS",
      "style": null
    },
    {
      "blockId": "P0100",
      "kind": "paragraph",
      "text": "(Ban hành theo Thông tư số      /2026/TT-VKSTC",
      "style": null
    },
    {
      "blockId": "P0101",
      "kind": "paragraph",
      "text": "ngày       /     /2026)",
      "style": null
    }
