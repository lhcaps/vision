    {
      "blockId": "P0070",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0071",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0072",
      "kind": "paragraph",
      "text": "Mẫu này được dùng trong trường hợp hủy bỏ Quyết định tạm đình chỉ của cơ quan, người có thẩm quyền không có căn cứ và trái pháp luật",
      "style": null
    },
    {
      "blockId": "P0073",
      "kind": "paragraph",
      "text": "Trường hợp hủy bỏ Quyết định tạm đình chỉ vụ án hình sự đối với bị can là pháp nhân thương mại thì bổ sung căn cứ Điều 443 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0074",
      "kind": "paragraph",
      "text": "Chỉ ghi căn cứ này trong trường hợp vụ án có bị can là người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0075",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0076",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố bị can",
      "style": null
    },
    {
      "blockId": "P0077",
      "kind": "paragraph",
      "text": "Ghi họ tên người hoặc tên pháp nhân bị khởi tố",
      "style": null
    },
    {
      "blockId": "P0078",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ra Quyết định tạm đình chỉ vụ án hình sự đối với bị can",
      "style": null
    },
    {
      "blockId": "P0079",
      "kind": "paragraph",
      "text": "Ghi lý do hủy bỏ Quyết định tạm đình chỉ vụ án hình sự đối với bị can",
      "style": null
    },
    {
      "blockId": "P0080",
      "kind": "paragraph",
      "text": "Trường hợp Viện trưởng Viện kiểm sát hủy bỏ Quyết định tạm đình chỉ vụ án hình sự đối với bị can của Phó Viện trưởng Viện kiểm sát cấp mình thì ghi:",
      "style": null
    },
