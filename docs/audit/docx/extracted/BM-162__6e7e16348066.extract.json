      "style": null
    },
    {
      "blockId": "P0024",
      "kind": "paragraph",
      "text": "có mặt theo đúng thời gian và địa điểm nêu trên./.",
      "style": null
    },
    {
      "blockId": "P0025",
      "kind": "paragraph",
