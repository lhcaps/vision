    {
      "blockId": "P0027",
      "kind": "paragraph",
      "text": "KIỂM SÁT VIÊN",
      "style": null
    },
    {
      "blockId": "P0028",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0029",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0030",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0031",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0032",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/",
      "style": null
    },
    {
      "blockId": "P0033",
      "kind": "paragraph",
      "text": "thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0034",
      "kind": "paragraph",
      "text": "Ghi họ tên người được mời. Trường hợp mời cơ quan, tổ chức thì ghi đầy đủ thông tin của cơ quan, tổ chức (gồm: tên, địa chỉ đặt trụ sở chính; số đăng ký kinh doanh, quốc tịch, họ tên người đại diện theo pháp luật (nếu có),",
      "style": null
    },
    {
      "blockId": "P0035",
      "kind": "paragraph",
      "text": "Ghi rõ tên, địa chỉ nơi tiến hành hoạt động tố tụng",
      "style": null
    },
    {
      "blockId": "P0036",
      "kind": "paragraph",
      "text": "Ghi rõ lý do mời",
      "style": null
    },
    {
      "blockId": "P0037",
