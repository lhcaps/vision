      "style": null
    },
    {
      "blockId": "P0081",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0082",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0083",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0084",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0085",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0086",
      "kind": "paragraph",
      "text": "Trường hợp Quyết định phục hồi vụ án hình sự đối với bị can bị đình chỉ thì căn cứ Điều 248 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0087",
      "kind": "paragraph",
      "text": "Trường hợp Quyết định phục hồi vụ án hình sự đối với bị can là pháp nhân thì bổ sung căn cứ Điều 431 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0088",
      "kind": "paragraph",
      "text": "Chỉ ghi căn cứ này trong trường hợp vụ án có bị can là người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0089",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0090",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố bị can",
      "style": null
    },
    {
      "blockId": "P0091",
      "kind": "paragraph",
      "text": "Ghi họ tên người hoặc tên pháp nhân bị khởi tố",
      "style": null
    },
    {
      "blockId": "P0092",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người ra Quyết định tạm đình chỉ (hoặc đình chỉ) vụ án hình sự đối với bị can",
      "style": null
    },
    {
      "blockId": "P0093",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người ra Quyết định hủy bỏ Quyết định tạm đình chỉ (hoặc đình chỉ) vụ án hình sự đối với bị can",
      "style": null
    },
    {
      "blockId": "P0094",
      "kind": "paragraph",
      "text": "Ghi lý do phục hồi vụ án hình sự đối với bị can theo quy định tại Điều 249 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0095",
      "kind": "paragraph",
      "text": "Trường hợp Quyết định phục hồi vụ án hình sự đối với bị can là pháp nhân thì ghi đầy đủ thông tin về pháp nhân (gồm: tên pháp nhân, địa chỉ đặt trụ sở chính, số đăng ký kinh doanh, quốc tịch, họ tên người đại diện theo pháp luật,",
      "style": null
    },
    {
      "blockId": "P0096",
      "kind": "paragraph",
      "text": "Ghi rõ nội dung các vấn đề khác có liên quan cần giải quyết",
      "style": null
    },
    {
      "blockId": "P0097",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, tổ chức, cá nhân có liên quan",
      "style": null
    },
    {
      "blockId": "P0098",
      "kind": "paragraph",
      "text": "Ghi chức danh người ký",
      "style": null
    },
    {
      "blockId": "P0099",
