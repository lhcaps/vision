      "style": null
    },
    {
      "blockId": "P0042",
      "kind": "paragraph",
      "text": "..............................................",
      "style": null
    },
    {
      "blockId": "P0043",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0044",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0045",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0046",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0047",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh, thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0048",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0049",
      "kind": "paragraph",
      "text": "Ghi rõ lý do, căn cứ theo quy định tại khoản 1 Điều 247 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0050",
      "kind": "paragraph",
      "text": "Ghi rõ khởi tố theo Quyết định khởi tố vụ án hình sự số",
      "style": null
    },
    {
      "blockId": "P0051",
      "kind": "paragraph",
      "text": "ngày",
      "style": null
    },
    {
      "blockId": "P0052",
      "kind": "paragraph",
      "text": "tháng",
      "style": null
    },
    {
      "blockId": "P0053",
