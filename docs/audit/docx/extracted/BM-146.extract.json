    {
      "blockId": "P0032",
      "kind": "paragraph",
      "text": "Điều 1. Tạm đình chỉ vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0033",
      "kind": "paragraph",
      "text": "Điều 2. Việc giám định/định giá tài sản/yêu cầu cơ quan, tổ chức, cá nhân cung cấp tài liệu, đồ vật/tương trợ tư pháp tiếp tục được tiến hành cho đến khi có kết quả",
      "style": null
    },
    {
      "blockId": "P0034",
      "kind": "paragraph",
      "text": "Điều 3. Xử lý",
      "style": null
    },
    {
      "blockId": "P0035",
      "kind": "paragraph",
      "text": "....",
      "style": null
    },
    {
      "blockId": "P0036",
      "kind": "paragraph",
      "text": "Điều 4. Yêu cầu",
      "style": null
    },
    {
      "blockId": "P0037",
      "kind": "paragraph",
      "text": "thực hiện Quyết định này theo quy định của pháp luật./.",
      "style": null
    },
    {
      "blockId": "P0038",
      "kind": "paragraph",
      "text": "Nơi nhận:",
      "style": null
