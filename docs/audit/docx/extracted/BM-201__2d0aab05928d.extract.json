    {
      "blockId": "P0052",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0053",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0054",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0055",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0056",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0057",
      "kind": "paragraph",
      "text": "Mẫu này dùng trong trường hợp giải quyết khiếu nại/kiến nghị về Quyết định áp dụng/Quyết định không áp dụng biện pháp xử lý chuyển hướng tại cộng đồng của Viện kiểm sát và của Thủ trưởng Cơ quan điều tra",
      "style": null
    },
    {
      "blockId": "P0058",
      "kind": "paragraph",
      "text": "Ghi họ tên người khiếu nại; trường hợp cơ quan, tổ chức là bị hại khiếu nại thì ghi rõ tên, địa chỉ của cơ quan, tổ chức và họ tên người đại diện của cơ quan, tổ chức/tên cơ quan, người có thẩm quyền điều tra đã kiến nghị",
      "style": null
    },
    {
      "blockId": "P0059",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người ra Quyết định áp dụng/không áp dụng biện pháp xử lý chuyển hướng tại cộng đồng",
      "style": null
    },
    {
      "blockId": "P0060",
      "kind": "paragraph",
      "text": "Ghi lý do chấp nhận/không chấp nhận khiếu nại/kiến nghị và hủy bỏ/giữ nguyên Quyết định áp dụng/không áp dụng biện pháp xử lý chuyển hướng tại cộng đồng",
      "style": null
    },
    {
      "blockId": "P0061",
      "kind": "paragraph",
      "text": "Ghi họ tên người chưa thành niên",
      "style": null
    },
    {
      "blockId": "P0062",
      "kind": "paragraph",
      "text": "Ghi rõ khởi tố theo Quyết định khởi tố vụ án hình sự số",
      "style": null
    },
    {
      "blockId": "P0063",
      "kind": "paragraph",
      "text": "ngày",
      "style": null
    },
    {
      "blockId": "P0064",
