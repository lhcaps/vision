      "text": ".............................................",
      "style": null
    },
    {
      "blockId": "P0111",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0112",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0113",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0114",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0115",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0116",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0117",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định khởi tố bị can",
      "style": null
    },
    {
      "blockId": "P0118",
      "kind": "paragraph",
      "text": "Ghi họ tên người hoặc tên pháp nhân bị khởi tố",
      "style": null
    },
    {
      "blockId": "P0119",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định nhập vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0120",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Quyết định phục hồi vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0121",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền ra Bản kết luận điều tra vụ án hình sự đề nghị truy tố (Bản kết luận điều tra bổ sung, nếu có)",
      "style": null
    },
    {
      "blockId": "P0122",
      "kind": "paragraph",
      "text": "Ghi rõ bút lục để chứng minh",
      "style": null
    },
    {
      "blockId": "P0123",
      "kind": "paragraph",
      "text": "Trường truy tố bị can là pháp nhân thì ghi đầy đủ thông tin về pháp nhân (gồm: tên pháp nhân, địa chỉ đặt trụ sở chính, số đăng ký kinh doanh, quốc tịch, họ tên người đại diện theo pháp luật,",
      "style": null
    },
    {
      "blockId": "P0124",
      "kind": "paragraph",
      "text": "Ghi tên Tòa án có thẩm quyền xét xử",
      "style": null
    },
    {
      "blockId": "P0125",
      "kind": "paragraph",
      "text": "Chỉ ghi phần này nếu thuộc trường hợp quy định tại khoản 1 Điều 246 của Bộ luật Tố tụng hình sự",
      "style": null
    },
    {
      "blockId": "P0126",
      "kind": "paragraph",
      "text": "Ghi chức danh người ký",
      "style": null
    },
    {
      "blockId": "P0127",
      "kind": "paragraph",
      "text": "Mẫu số 156/HS",
      "style": null
    },
    {
