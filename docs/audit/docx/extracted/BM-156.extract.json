      "style": null
    },
    {
      "blockId": "P0056",
      "kind": "paragraph",
      "text": "(Bản kết luận điều tra bổ sung số",
      "style": null
    },
    {
      "blockId": "P0057",
      "kind": "paragraph",
      "text": "ngày",
      "style": null
    },
    {
      "blockId": "P0058",
