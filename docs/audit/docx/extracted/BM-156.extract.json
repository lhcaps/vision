      "style": null
    },
    {
      "blockId": "P0061",
      "kind": "paragraph",
      "text": "...;",
      "style": null
    },
    {
      "blockId": "P0062",
      "kind": "paragraph",
      "text": "Trên cơ sở kết quả điều tra đã xác định được như sau:",
      "style": null
    },
    {
      "blockId": "P0063",
      "kind": "paragraph",
      "text": "- Diễn biến hành vi phạm tội (hành vi của bị can; ngày, giờ, tháng, năm; địa điểm; thủ đoạn; động cơ, mục đích; tính chất, mức độ thiệt hại do hành vi phạm tội gây ra; nguyên nhân, điều kiện ... )",
      "style": null
    },
    {
      "blockId": "P0064",
      "kind": "paragraph",
      "text": "- Phân tích, đánh giá tình tiết tăng nặng, giảm nhẹ và tình tiết khác có ý nghĩa đối với vụ án;",
      "style": null
    },
    {
      "blockId": "P0065",
      "kind": "paragraph",
      "text": "- Việc thu giữ, tạm giữ tài liệu, đồ vật; xử lý vật chứng;",
      "style": null
    },
    {
      "blockId": "P0066",
      "kind": "paragraph",
      "text": "- Phần dân sự (nếu có);",
      "style": null
    },
    {
      "blockId": "P0067",
      "kind": "paragraph",
      "text": "- ...................................................................................................................................",
      "style": null
    },
    {
      "blockId": "P0068",
      "kind": "paragraph",
      "text": "Căn cứ vào các tình tiết và chứng cứ nêu trên,",
      "style": null
    },
    {
      "blockId": "P0069",
      "kind": "paragraph",
      "text": "KẾT LUẬN",
      "style": null
    },
    {
      "blockId": "P0070",
      "kind": "paragraph",
      "text": "Phần này nêu những nội dung sau đây:",
      "style": null
    },
    {
      "blockId": "P0071",
      "kind": "paragraph",
      "text": "- Tổng hợp ngắn gọn hành vi phạm tội của bị can hoặc từng bị can; tính chất, mức độ, hậu quả của hành vi phạm tội; vai trò của từng bị can trong vụ án (chú ý sắp xếp theo trật tự căn cứ vào mức độ nguy hiểm của hành vi, từ tội đặc biệt nghiêm trọng, rất nghiêm trọng, nghiêm trọng, ít nghiêm trọng).",
      "style": null
    },
    {
      "blockId": "P0072",
      "kind": "paragraph",
      "text": "- Trường hợp vắng mặt bị can thì bổ sung các nội dung được quy định tại khoản 2 Điều 243 của Bộ luật Tố tụng hình sự.",
      "style": null
    },
    {
      "blockId": "P0073",
      "kind": "paragraph",
      "text": "Như vậy có đủ căn cứ để xác định các bị can có lý lịch dưới đây đã phạm tội (các tội) như sau:",
      "style": null
    },
    {
      "blockId": "P0074",
      "kind": "paragraph",
      "text": "- Nêu lý lịch từng bị can (chú ý sắp xếp theo thứ tự căn cứ vào vai trò của từng bị can), gồm",
      "style": null
    },
    {
      "blockId": "P0075",
      "kind": "paragraph",
      "text": "+ Họ tên, tên gọi khác; giới tính, ngày, tháng, năm sinh, nơi sinh, nơi cư trú, quốc tịch, dân tộc, tôn giáo, trình độ học vấn, nghề nghiệp, chức vụ trước khi phạm tội (Đảng, chính quyền, đoàn thể);",
      "style": null
    },
    {
      "blockId": "P0076",
      "kind": "paragraph",
      "text": "+ Họ tên cha, mẹ (sinh năm, sống hay chết), anh chị em ruột, vợ/chồng, có mấy con, lớn nhất mấy tuổi, nhỏ nhất mấy tuổi;",
      "style": null
    },
    {
      "blockId": "P0077",
      "kind": "paragraph",
      "text": "+ Nếu bị can là thương binh, bệnh binh hoặc có huân, huy chương hoặc các danh hiệu Nhà nước phong tặng khác (cán bộ hoạt động trước Cách mạng tháng 8, anh hùng lao động, anh hùng các lực lượng vũ trang, bà mẹ Việt Nam anh hùng hoặc thân nhân của bị can là thương binh, liệt sỹ) thì cần ghi rõ.",
      "style": null
    },
    {
      "blockId": "P0078",
      "kind": "paragraph",
      "text": "Tiền sự (chỉ ghi tiền sự còn thời hạn xem xét):.............................................................",
      "style": null
    },
    {
      "blockId": "P0079",
      "kind": "paragraph",
      "text": "Tiền án: ghi rõ ngày xét xử, Toà án xét xử, tội danh, điểm, khoản, Điều Bộ luật Hình sự, hình phạt (các thông tin về việc thi hành bản án, quyết định của Tòa án) .............................................................................................................................................",
      "style": null
    },
    {
      "blockId": "P0080",
      "kind": "paragraph",
      "text": "Bị can",
      "style": null
    },
    {
      "blockId": "P0081",
      "kind": "paragraph",
      "text": "đang bị áp dụng biện pháp ngăn chặn, biện pháp cưỡng chế",
      "style": null
    },
    {
      "blockId": "P0082",
      "kind": "paragraph",
      "text": "; từ",
      "style": null
    },
    {
      "blockId": "P0083",
      "kind": "paragraph",
      "text": "đến",
      "style": null
    },
    {
      "blockId": "P0084",
      "kind": "paragraph",
      "text": "- Khẳng định:",
      "style": null
    },
    {
      "blockId": "P0085",
      "kind": "paragraph",
      "text": "+ Bị can ... phạm tội gì, theo quy định tại điểm, khoản, điều nào của Bộ luật Hình sự (lưu ý trích dẫn tên điều luật).",
      "style": null
    },
    {
      "blockId": "P0086",
      "kind": "paragraph",
      "text": "+ Áp dụng tình tiết tăng nặng và tình tiết giảm nhẹ trách nhiệm hình sự theo quy định tại điểm, khoản, điều nào của Bộ luật Hình sự.",
      "style": null
    },
    {
      "blockId": "P0087",
      "kind": "paragraph",
      "text": "Trong vụ án nếu có người (hoặc pháp nhân) đã được đình chỉ, hay tạm đình chỉ, tách ra để xử lý ở vụ án khác, không khởi tố để xử lý bằng biện pháp khác thì cũng ghi rõ cùng với căn cứ pháp lý.",
      "style": null
    },
    {
      "blockId": "P0088",
      "kind": "paragraph",
      "text": "Bởi các lẽ trên,",
      "style": null
    },
    {
      "blockId": "P0089",
      "kind": "paragraph",
      "text": "QUYẾT ĐỊNH",
      "style": null
    },
    {
      "blockId": "P0090",
      "kind": "paragraph",
      "text": "1. Truy tố ra trước Toà án",
      "style": null
    },
    {
      "blockId": "P0091",
      "kind": "paragraph",
      "text": "để xét xử bị can (hoặc các bị can - nêu rõ họ tên) có lý lịch và hành vi nêu trên về tội hoặc các tội. Nếu nhiều bị can cùng bị truy tố về một tội và áp dụng điểm, khoản, điều giống nhau thì ghi tất cả họ tên bị can đến tội danh, đến điểm, khoản, điều của Bộ luật Hình sự.",
      "style": null
    },
    {
      "blockId": "P0092",
      "kind": "paragraph",
      "text": "Cáo trạng này thay thế Cáo trạng số",
      "style": null
    },
    {
      "blockId": "P0093",
      "kind": "paragraph",
      "text": "ngày",
      "style": null
    },
    {
      "blockId": "P0094",
      "kind": "paragraph",
      "text": "tháng",
      "style": null
    },
    {
      "blockId": "P0095",
      "kind": "paragraph",
      "text": "năm",
      "style": null
    },
    {
      "blockId": "P0096",
      "kind": "paragraph",
      "text": "của",
      "style": null
    },
    {
      "blockId": "P0097",
      "kind": "paragraph",
      "text": "2. Kèm theo Cáo trạng có:",
      "style": null
    },
    {
      "blockId": "P0098",
      "kind": "paragraph",
      "text": "- Hồ sơ vụ án gồm có:",
      "style": null
    },
    {
      "blockId": "P0099",
      "kind": "paragraph",
      "text": "tập, bằng",
      "style": null
    },
    {
      "blockId": "P0100",
      "kind": "paragraph",
      "text": "tờ; đánh số thứ tự từ 01 đến",
      "style": null
    },
    {
      "blockId": "P0101",
      "kind": "paragraph",
      "text": "- Bản kê vật chứng (nếu có).",
      "style": null
    },
    {
      "blockId": "P0102",
      "kind": "paragraph",
      "text": "- Danh sách những người Viện kiểm sát đề nghị Tòa án triệu tập đến phiên tòa.",
      "style": null
    },
    {
      "blockId": "P0103",
      "kind": "paragraph",
      "text": "../.",
      "style": null
    },
    {
      "blockId": "P0104",
      "kind": "paragraph",
      "text": "Nơi nhận:",
      "style": null
    },
    {
      "blockId": "P0105",
      "kind": "paragraph",
      "text": "- 13...;",
      "style": null
    },
    {
      "blockId": "P0106",
