      "text": "... về vụ việc",
      "style": null
    },
    {
      "blockId": "P0016",
      "kind": "paragraph",
      "text": "... có dấu hiệu tội phạm",
      "style": null
    },
    {
      "blockId": "P0017",
      "kind": "paragraph",
      "text": "quy định tại khoản ... Điều",
      "style": null
    },
    {
      "blockId": "P0018",
      "kind": "paragraph",
      "text": "của Bộ luật Hình sự,",
      "style": null
    },
    {
      "blockId": "P0019",
      "kind": "paragraph",
      "text": "QUYẾT ĐỊNH:",
      "style": null
    },
    {
      "blockId": "P0020",
      "kind": "paragraph",
      "text": "Điều 1. Khởi tố vụ án hình sự về tội",
      "style": null
    },
    {
      "blockId": "P0021",
      "kind": "paragraph",
      "text": "quy định tại khoản ... Điều ... của Bộ luật Hình sự.",
      "style": null
    },
    {
      "blockId": "P0022",
      "kind": "paragraph",
      "text": "Điều 2. Yêu cầu",
      "style": null
    },
    {
      "blockId": "P0023",
      "kind": "paragraph",
      "text": "tiến hành điều tra theo quy định của Bộ luật Tố tụng hình sự./.",
      "style": null
    },
    {
      "blockId": "P0024",
      "kind": "paragraph",
      "text": "Nơi nhận:",
      "style": null
    },
    {
      "blockId": "P0025",
      "kind": "paragraph",
      "text": "- Lưu: HSVA, HSKS, VP.",
      "style": null
    },
    {
      "blockId": "P0026",
      "kind": "paragraph",
      "text": "(Ký, ghi rõ họ tên, đóng dấu)",
      "style": null
    },
    {
      "blockId": "P0027",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát cấp trên trực tiếp",
      "style": null
    },
    {
      "blockId": "P0028",
      "kind": "paragraph",
      "text": "Ghi tên Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0029",
      "kind": "paragraph",
      "text": "Viết tắt tên Viện kiểm sát ban hành - đơn vị phụ trách (nếu có)",
      "style": null
    },
    {
      "blockId": "P0030",
      "kind": "paragraph",
      "text": "Ghi địa danh là tên tỉnh/thành phố nơi đặt trụ sở của Viện kiểm sát ban hành",
      "style": null
    },
    {
      "blockId": "P0031",
      "kind": "paragraph",
      "text": "Nêu rõ căn cứ khởi tố theo quy định tại các khoản 1, 2, 3, 4 hoặc 5",
      "style": null
    },
    {
      "blockId": "P0032",
      "kind": "paragraph",
      "text": "Điều 143 của Bộ luật Tố tụng hình sự; trường hợp khởi tố do hủy bỏ Quyết định không khởi tố vụ án hình sự của cơ quan, người có thẩm quyền giải quyết nguồn tin về tội phạm thì bổ sung căn cứ Quyết định hủy bỏ Quyết định không khởi tố vụ án hình sự",
      "style": null
    },
    {
      "blockId": "P0033",
      "kind": "paragraph",
      "text": "Trích dẫn ngắn gọn nội dung vụ việc (nguồn cung cấp, thời gian, địa điểm, hành vi có dấu hiệu tội phạm,",
      "style": null
    },
    {
      "blockId": "P0034",
      "kind": "paragraph",
      "text": "Ghi tên cơ quan, người có thẩm quyền điều tra",
      "style": null
    },
    {
      "blockId": "P0035",
      "kind": "paragraph",
      "text": "Ghi chức danh người ký",
      "style": null
    },
    {
      "blockId": "P0036",
      "kind": "paragraph",
      "text": "Mẫu số 23/HS",
      "style": null
