      "text": "VIỆN TRƯỞNG VIỆN KIỂM SÁT2",
      "style": null
    },
    {
      "blockId": "P0013",
      "kind": "paragraph",
      "text": "Căn cứ các điều 41, 143, 153, 154, 159, 161 và 165 (hoặc 432) của Bộ luật Tố tụng hình sự;",
      "style": null
    },
    {
      "blockId": "P0014",
      "kind": "paragraph",
      "text": "Xét thấy",
      "style": null
    },
    {
      "blockId": "P0015",
