generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model agencies {
  id               BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  agency_code      String?     @unique(map: "uq_agencies_code") @db.VarChar(100)
  agency_name      String      @db.VarChar(255)
  agency_type      String      @db.VarChar(50)
  parent_agency_id BigInt?     @db.UnsignedBigInt
  address          String?     @db.Text
  phone            String?     @db.VarChar(50)
  is_active        Boolean     @default(true)
  created_at       DateTime    @default(now()) @db.DateTime(0)
  updated_at       DateTime    @default(now()) @db.DateTime(0)
  agencies         agencies?   @relation("agenciesToagencies", fields: [parent_agency_id], references: [id], onUpdate: NoAction, map: "fk_agencies_parent")
  other_agencies   agencies[]  @relation("agenciesToagencies")
  cases            cases[]
  officials        officials[]

  @@index([parent_agency_id], map: "fk_agencies_parent")
  @@index([agency_name], map: "idx_agencies_name")
  @@index([agency_type], map: "idx_agencies_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model audit_logs {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
