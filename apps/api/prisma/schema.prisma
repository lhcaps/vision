  old_value_json Json?
  new_value_json Json?
  ip_address     String?  @db.VarChar(100)
  user_agent     String?  @db.Text
  created_at     DateTime @default(now()) @db.DateTime(0)
  cases          cases?   @relation(fields: [case_id], references: [id], onUpdate: NoAction, map: "fk_audit_logs_case")

  @@index([action], map: "idx_audit_logs_action")
  @@index([actor_name], map: "idx_audit_logs_actor")
  @@index([case_id], map: "idx_audit_logs_case")
  @@index([created_at], map: "idx_audit_logs_created_at")
