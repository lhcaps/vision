{
  "name": "@visionflow/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -P tsconfig.json src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/client": "6.19.3",
    "@types/multer": "^2.1.0",
    "@visionflow/contracts": "workspace:*",
    "bullmq": "^5.76.3",
    "dotenv": "^16.4.7",
    "ioredis": "^5.10.1",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "^22.19.17",
    "@types/sharp": "^0.32.0",
    "@types/uuid": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.1.2"
  }
}
