{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2023",
    "lib": ["ES2023"],
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*spec.ts",
    "storage",
    "storage/**",
    "storage/**/*",
    "./storage",
    "./storage/**",
    "./storage/**/*",
    "../storage",
    "../storage/**",
    "../storage/**/*",
    "../../storage",
    "../../storage/**",
    "../../storage/**/*",
    "**/storage/**",
    "**/code-backups/**",
    "../../storage/code-backups/**",
    "prisma"
  ]
}
